-- SuspensionStatus
    CASE 
        -- Condition 1: suspendDuration is empty/0/not present AND actionDuration NOT defined
        WHEN (
            INSTR(b.endpointConfig, '"suspendDuration"') = 0
            OR INSTR(b.endpointConfig, '"suspendDuration":""') > 0
            OR INSTR(b.endpointConfig, '"suspendDuration":"0"') > 0
        )
        AND INSTR(b.endpointConfig, '"actionDuration"') = 0
        THEN 'SuspensionDisabled - Endpoint will timeout at 179000ms'
        
        -- Condition 2: suspendDuration is empty/0/not present AND actionDuration IS defined
        WHEN (
            INSTR(b.endpointConfig, '"suspendDuration"') = 0
            OR INSTR(b.endpointConfig, '"suspendDuration":""') > 0
            OR INSTR(b.endpointConfig, '"suspendDuration":"0"') > 0
        )
        AND INSTR(b.endpointConfig, '"actionDuration"') > 0
        THEN 'SuspensionDisabled - Endpoint will timeout based on actionDuration'
        
        -- Condition 3: No suspend AND no endpoint found in any sequence column
        WHEN INSTR(LOWER(NVL(b.endpointConfig, ' ')), 'suspend') = 0
          AND (b.inSequence_content IS NULL OR DBMS_LOB.INSTR(LOWER(b.inSequence_content), 'suspend') = 0)
          AND (b.outSequence_content IS NULL OR DBMS_LOB.INSTR(LOWER(b.outSequence_content), 'suspend') = 0)
          AND (b.faultSequence_content IS NULL OR DBMS_LOB.INSTR(LOWER(b.faultSequence_content), 'suspend') = 0)
          AND (b.inSequence_reg_path IS NULL OR DBMS_LOB.INSTR(LOWER(b.inSequence_reg_path), 'suspend') = 0)
          AND (b.outSequence_reg_path IS NULL OR DBMS_LOB.INSTR(LOWER(b.outSequence_reg_path), 'suspend') = 0)
          AND (b.faultSequence_reg_path IS NULL OR DBMS_LOB.INSTR(LOWER(b.faultSequence_reg_path), 'suspend') = 0)
          AND (b.inSequence_content IS NULL OR DBMS_LOB.INSTR(LOWER(b.inSequence_content), 'endpoint') = 0)
          AND (b.outSequence_content IS NULL OR DBMS_LOB.INSTR(LOWER(b.outSequence_content), 'endpoint') = 0)
          AND (b.faultSequence_content IS NULL OR DBMS_LOB.INSTR(LOWER(b.faultSequence_content), 'endpoint') = 0)
          AND (b.inSequence_reg_path IS NULL OR DBMS_LOB.INSTR(LOWER(b.inSequence_reg_path), 'endpoint') = 0)
          AND (b.outSequence_reg_path IS NULL OR DBMS_LOB.INSTR(LOWER(b.outSequence_reg_path), 'endpoint') = 0)
          AND (b.faultSequence_reg_path IS NULL OR DBMS_LOB.INSTR(LOWER(b.faultSequence_reg_path), 'endpoint') = 0)
        THEN 'NoSuspensionDefined - Endpoint will timeout at 179000ms'
        
        ELSE NULL
    END AS SuspensionStatus,
