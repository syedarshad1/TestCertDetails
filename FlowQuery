WITH blob_to_clob AS (
    SELECT 
        a.API_NAME,
        a.API_UUID,
        a.REVISIONS_CREATED,
        r.reg_content_id,
        r.reg_uuid,
        r.reg_name,
        r.reg_media_type,
        p.reg_path_value,
        r.reg_last_updated_time,
        TO_CLOB(UTL_RAW.CAST_TO_VARCHAR2(DBMS_LOB.SUBSTR(c.reg_content_data, 2000, 1))) ||
        TO_CLOB(UTL_RAW.CAST_TO_VARCHAR2(DBMS_LOB.SUBSTR(c.reg_content_data, 2000, 2001))) ||
        TO_CLOB(UTL_RAW.CAST_TO_VARCHAR2(DBMS_LOB.SUBSTR(c.reg_content_data, 2000, 4001))) ||
        TO_CLOB(UTL_RAW.CAST_TO_VARCHAR2(DBMS_LOB.SUBSTR(c.reg_content_data, 2000, 6001))) ||
        TO_CLOB(UTL_RAW.CAST_TO_VARCHAR2(DBMS_LOB.SUBSTR(c.reg_content_data, 2000, 8001))) ||
        TO_CLOB(UTL_RAW.CAST_TO_VARCHAR2(DBMS_LOB.SUBSTR(c.reg_content_data, 2000, 10001))) ||
        TO_CLOB(UTL_RAW.CAST_TO_VARCHAR2(DBMS_LOB.SUBSTR(c.reg_content_data, 2000, 12001))) AS full_xml
    FROM COCT42_AM.AM_API a
    JOIN coct42_reg.reg_path p
        ON p.reg_path_value = CASE 
            WHEN a.REVISIONS_CREATED = 0 
            THEN '/_system/governance/apimgt/applicationdata/apis/' || a.API_UUID
            ELSE '/_system/governance/apimgt/applicationdata/apis/' || a.API_UUID || '/' || a.REVISIONS_CREATED
        END
    JOIN coct42_reg.reg_resource r
        ON r.reg_path_id = p.reg_path_id
        AND r.reg_name = 'api'
    JOIN coct42_reg.reg_content c
        ON c.reg_content_id = r.reg_content_id
),
tag_positions AS (
    SELECT 
        b.*,
        DBMS_LOB.INSTR(full_xml, '<endpointConfig>') AS ec_start,
        DBMS_LOB.INSTR(full_xml, '</endpointConfig>') AS ec_end,
        DBMS_LOB.INSTR(full_xml, '<inSequence>') AS is_start,
        DBMS_LOB.INSTR(full_xml, '</inSequence>') AS is_end,
        DBMS_LOB.INSTR(full_xml, '<outSequence>') AS os_start,
        DBMS_LOB.INSTR(full_xml, '</outSequence>') AS os_end,
        DBMS_LOB.INSTR(full_xml, '<faultSequence>') AS fs_start,
        DBMS_LOB.INSTR(full_xml, '</faultSequence>') AS fs_end
    FROM blob_to_clob b
),
extracted AS (
    SELECT 
        API_NAME,
        API_UUID,
        REVISIONS_CREATED,
        reg_content_id,
        reg_uuid,
        reg_name,
        reg_media_type,
        reg_path_value,
        reg_last_updated_time,
        CASE WHEN ec_start > 0 
             THEN DBMS_LOB.SUBSTR(full_xml, ec_end - ec_start - 16, ec_start + 16) 
        END AS endpointConfig,
        CASE WHEN is_start > 0 
             THEN DBMS_LOB.SUBSTR(full_xml, is_end - is_start - 12, is_start + 12) 
        END AS inSequence,
        CASE WHEN os_start > 0 
             THEN DBMS_LOB.SUBSTR(full_xml, os_end - os_start - 13, os_start + 13) 
        END AS outSequence,
        CASE WHEN fs_start > 0 
             THEN DBMS_LOB.SUBSTR(full_xml, fs_end - fs_start - 15, fs_start + 15) 
        END AS faultSequence
    FROM tag_positions
),
seq_lookup_all AS (
    SELECT 
        r_s.reg_name AS seq_reg_name,
        r_s.reg_content_id AS seq_content_id,
        r_s.reg_media_type AS seq_media_type,
        p_s.reg_path_value AS seq_path,
        r_s.reg_last_updated_time AS seq_last_updated,
        TO_CLOB(UTL_RAW.CAST_TO_VARCHAR2(DBMS_LOB.SUBSTR(c_s.reg_content_data, 2000, 1))) ||
        TO_CLOB(UTL_RAW.CAST_TO_VARCHAR2(DBMS_LOB.SUBSTR(c_s.reg_content_data, 2000, 2001))) ||
        TO_CLOB(UTL_RAW.CAST_TO_VARCHAR2(DBMS_LOB.SUBSTR(c_s.reg_content_data, 2000, 4001))) ||
        TO_CLOB(UTL_RAW.CAST_TO_VARCHAR2(DBMS_LOB.SUBSTR(c_s.reg_content_data, 2000, 6001))) ||
        TO_CLOB(UTL_RAW.CAST_TO_VARCHAR2(DBMS_LOB.SUBSTR(c_s.reg_content_data, 2000, 8001))) ||
        TO_CLOB(UTL_RAW.CAST_TO_VARCHAR2(DBMS_LOB.SUBSTR(c_s.reg_content_data, 2000, 10001))) AS seq_content
    FROM coct42_reg.reg_resource r_s
    JOIN coct42_reg.reg_path p_s
        ON r_s.reg_path_id = p_s.reg_path_id
    JOIN coct42_reg.reg_content c_s
        ON c_s.reg_content_id = r_s.reg_content_id
    WHERE r_s.reg_media_type IN (
        'application/vnd.wso2.sequence',
        'application/xml'
    )
),
seq_lookup_ranked AS (
    SELECT 
        seq_reg_name,
        seq_content_id,
        seq_media_type,
        seq_path,
        seq_last_updated,
        seq_content,
        ROW_NUMBER() OVER (
            PARTITION BY seq_reg_name
            ORDER BY seq_last_updated DESC
        ) AS rn
    FROM seq_lookup_all
),
seq_lookup AS (
    SELECT seq_reg_name, seq_content_id, seq_media_type, seq_path, seq_last_updated, seq_content
    FROM seq_lookup_ranked
    WHERE rn = 1
)
SELECT 
    e.API_NAME,
    e.API_UUID,
    e.REVISIONS_CREATED,
    e.reg_content_id,
    e.reg_uuid,
    e.reg_name,
    e.reg_media_type,
    e.reg_path_value,
    e.reg_last_updated_time,
    e.endpointConfig,
    
    e.inSequence AS inSequence_name,
    CASE 
        WHEN e.inSequence IS NOT NULL AND isl.seq_content IS NOT NULL 
            THEN isl.seq_content
        WHEN e.inSequence IS NOT NULL 
            THEN TO_CLOB('NOT FOUND')
        ELSE TO_CLOB(NULL)
    END AS inSequence_content,
    
    e.outSequence AS outSequence_name,
    CASE 
        WHEN e.outSequence IS NOT NULL AND osl.seq_content IS NOT NULL 
            THEN osl.seq_content
        WHEN e.outSequence IS NOT NULL 
            THEN TO_CLOB('NOT FOUND')
        ELSE TO_CLOB(NULL)
    END AS outSequence_content,
    
    e.faultSequence AS faultSequence_name,
    CASE 
        WHEN e.faultSequence IS NOT NULL AND fsl.seq_content IS NOT NULL 
            THEN fsl.seq_content
        WHEN e.faultSequence IS NOT NULL 
            THEN TO_CLOB('NOT FOUND')
        ELSE TO_CLOB(NULL)
    END AS faultSequence_content

FROM extracted e
LEFT JOIN seq_lookup isl
    ON isl.seq_reg_name LIKE e.inSequence || '%'
LEFT JOIN seq_lookup osl
    ON osl.seq_reg_name LIKE e.outSequence || '%'
LEFT JOIN seq_lookup fsl
    ON fsl.seq_reg_name LIKE e.faultSequence || '%'
ORDER BY e.reg_last_updated_time DESC;
