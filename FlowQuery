-- Condition 5: FoundSuspend=Yes BUT NOT in endpointConfig AND inSequence_content has <initailDuration>0</initailDuration>
        WHEN INSTR(LOWER(NVL(b.endpointConfig, ' ')), 'suspend') = 0
        AND (
            (b.inSequence_content IS NOT NULL AND NVL(DBMS_LOB.INSTR(LOWER(b.inSequence_content), 'suspend'), 0) > 0)
            OR (b.outSequence_content IS NOT NULL AND NVL(DBMS_LOB.INSTR(LOWER(b.outSequence_content), 'suspend'), 0) > 0)
            OR (b.faultSequence_content IS NOT NULL AND NVL(DBMS_LOB.INSTR(LOWER(b.faultSequence_content), 'suspend'), 0) > 0)
            OR (b.inSequence_reg_path IS NOT NULL AND NVL(DBMS_LOB.INSTR(LOWER(b.inSequence_reg_path), 'suspend'), 0) > 0)
            OR (b.outSequence_reg_path IS NOT NULL AND NVL(DBMS_LOB.INSTR(LOWER(b.outSequence_reg_path), 'suspend'), 0) > 0)
            OR (b.faultSequence_reg_path IS NOT NULL AND NVL(DBMS_LOB.INSTR(LOWER(b.faultSequence_reg_path), 'suspend'), 0) > 0)
        )
        AND (
            (b.inSequence_content IS NOT NULL AND NVL(DBMS_LOB.INSTR(b.inSequence_content, '<initailDuration>0</initailDuration>'), 0) > 0)
            OR (b.outSequence_content IS NOT NULL AND NVL(DBMS_LOB.INSTR(b.outSequence_content, '<initailDuration>0</initailDuration>'), 0) > 0)
            OR (b.faultSequence_content IS NOT NULL AND NVL(DBMS_LOB.INSTR(b.faultSequence_content, '<initailDuration>0</initailDuration>'), 0) > 0)
            OR (b.inSequence_reg_path IS NOT NULL AND NVL(DBMS_LOB.INSTR(b.inSequence_reg_path, '<initailDuration>0</initailDuration>'), 0) > 0)
            OR (b.outSequence_reg_path IS NOT NULL AND NVL(DBMS_LOB.INSTR(b.outSequence_reg_path, '<initailDuration>0</initailDuration>'), 0) > 0)
            OR (b.faultSequence_reg_path IS NOT NULL AND NVL(DBMS_LOB.INSTR(b.faultSequence_reg_path, '<initailDuration>0</initailDuration>'), 0) > 0)
        )
        THEN 'SuspensionDisabled - ThroughSequenceFile - Endpoint will timeout at 179000ms'
