
SELECT 
    a.API_UUID,
    a.API_NAME,
    a.API_VERSION,
    a.REVISIONS_CREATED
FROM COCT42_AM.AM_API a
INNER JOIN (
    SELECT 
        API_UUID, 
        MAX(REVISIONS_CREATED) AS MAX_REVISION
    FROM COCT42_AM.AM_API
    GROUP BY API_UUID
) b ON a.API_UUID = b.API_UUID 
    AND a.REVISIONS_CREATED = b.MAX_REVISION
ORDER BY a.API_NAME;
