SELECT a.API_UUID, a.REVISIONS_CREATED
FROM COCT42_AM.AM_API a
WHERE NOT EXISTS (
    SELECT 1
    FROM coct42_reg.reg_path p
    JOIN coct42_reg.reg_resource r
        ON r.reg_path_id = p.reg_path_id
        AND r.reg_name = 'api'
    WHERE p.reg_path_value = CASE 
        WHEN a.REVISIONS_CREATED = 0 
        THEN '/_system/governance/apimgt/applicationdata/apis/' || a.API_UUID
        ELSE '/_system/governance/apimgt/applicationdata/apis/' || a.API_UUID || '/' || a.REVISIONS_CREATED
    END
)
ORDER BY a.REVISIONS_CREATED;

SELECT p.reg_path_value
FROM coct42_reg.reg_path p
WHERE p.reg_path_value LIKE '%/_system/governance/apimgt/applicationdata/apis/' || '<paste_one_uuid_here>' || '%';
