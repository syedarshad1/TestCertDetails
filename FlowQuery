ELSE NULL
    END AS SuspensionStatus,
    
    -- actionDuration value extracted
    CASE 
        WHEN INSTR(b.endpointConfig, '"actionDuration":"') > 0
        THEN SUBSTR(
            b.endpointConfig,
            INSTR(b.endpointConfig, '"actionDuration":"') + 18,
            INSTR(b.endpointConfig, '"', INSTR(b.endpointConfig, '"actionDuration":"') + 18) 
            - (INSTR(b.endpointConfig, '"actionDuration":"') + 18)
        )
        ELSE NULL
    END AS actionDuration_value

FROM base_data b
ORDER BY b.reg_last_updated_time DESC;
