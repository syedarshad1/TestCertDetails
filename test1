WITH api_content AS (
    SELECT 
        a.API_NAME,
        a.CONTEXT,
        a.ORGANIZATION,
        a.API_UUID,
        r.reg_name,
        r.reg_content_id,
        p.reg_path_value,
        UTL_RAW.CAST_TO_VARCHAR2(HEXTORAW(DBMS_LOB.SUBSTR(c.reg_content_data, 2000, 1))) ||
        UTL_RAW.CAST_TO_VARCHAR2(HEXTORAW(DBMS_LOB.SUBSTR(c.reg_content_data, 2000, 2001))) ||
        UTL_RAW.CAST_TO_VARCHAR2(HEXTORAW(DBMS_LOB.SUBSTR(c.reg_content_data, 2000, 4001))) AS full_content
    FROM 
        COCT42_AM.AM_API a
        JOIN coct42_reg.reg_path p
            ON p.reg_path_value LIKE '%/_system/governance/apimgt/applicationdata/apis/' || a.API_UUID || '/%'
        JOIN coct42_reg.reg_resource r
            ON r.reg_path_id = p.reg_path_id
            AND r.reg_name = 'api'
            AND p.reg_path_value = (
                SELECT p2.reg_path_value
                FROM coct42_reg.reg_path p2
                JOIN coct42_reg.reg_resource r2
                    ON r2.reg_path_id = p2.reg_path_id
                    AND r2.reg_name = 'api'
                WHERE p2.reg_path_value LIKE '%/_system/governance/apimgt/applicationdata/apis/' || a.API_UUID || '/%'
                ORDER BY TO_NUMBER(REGEXP_SUBSTR(p2.reg_path_value, '\d+$')) DESC
                FETCH FIRST 1 ROW ONLY
            )
        JOIN coct42_reg.reg_content c
            ON c.reg_content_id = r.reg_content_id
    WHERE 
        a.API_UUID = 'c6f3df68-f5da-4d89-979e-f163db878f0a'
),
extracted AS (
    SELECT 
        API_NAME,
        CONTEXT,
        ORGANIZATION,
        API_UUID,
        reg_name,
        reg_content_id,
        reg_path_value,
        REGEXP_SUBSTR(full_content, '<endpointConfig>(.*?)</endpointConfig>', 1, 1, 'n', 1) AS EndpointConfig,
        REGEXP_SUBSTR(full_content, '<inSequence>(.*?)</inSequence>',         1, 1, 'n', 1) AS inSequence,
        REGEXP_SUBSTR(full_content, '<outSequence>(.*?)</outSequence>',       1, 1, 'n', 1) AS outSequence
    FROM api_content
),
-- Get inSequence file content from reg_resource/reg_content
in_seq_content AS (
    SELECT 
        r.reg_name,
        r.reg_content_id,
        UTL_RAW.CAST_TO_VARCHAR2(HEXTORAW(DBMS_LOB.SUBSTR(c.reg_content_data, 2000, 1))) ||
        UTL_RAW.CAST_TO_VARCHAR2(HEXTORAW(DBMS_LOB.SUBSTR(c.reg_content_data, 2000, 2001))) ||
        UTL_RAW.CAST_TO_VARCHAR2(HEXTORAW(DBMS_LOB.SUBSTR(c.reg_content_data, 2000, 4001))) AS seq_content
    FROM coct42_reg.reg_resource r
    JOIN coct42_reg.reg_path p   ON r.reg_path_id = p.reg_path_id
    JOIN coct42_reg.reg_content c ON c.reg_content_id = r.reg_content_id
    WHERE p.reg_path_value = '/_system/governance/apimgt/customsequences/in'
      AND r.reg_media_type  = 'application/vnd.wso2.sequence'
),
-- Get outSequence file content from reg_resource/reg_content
out_seq_content AS (
    SELECT 
        r.reg_name,
        r.reg_content_id,
        UTL_RAW.CAST_TO_VARCHAR2(HEXTORAW(DBMS_LOB.SUBSTR(c.reg_content_data, 2000, 1))) ||
        UTL_RAW.CAST_TO_VARCHAR2(HEXTORAW(DBMS_LOB.SUBSTR(c.reg_content_data, 2000, 2001))) ||
        UTL_RAW.CAST_TO_VARCHAR2(HEXTORAW(DBMS_LOB.SUBSTR(c.reg_content_data, 2000, 4001))) AS seq_content
    FROM coct42_reg.reg_resource r
    JOIN coct42_reg.reg_path p   ON r.reg_path_id = p.reg_path_id
    JOIN coct42_reg.reg_content c ON c.reg_content_id = r.reg_content_id
    WHERE p.reg_path_value = '/_system/governance/apimgt/customsequences/out'
      AND r.reg_media_type  = 'application/vnd.wso2.sequence'
)
SELECT
    e.API_NAME,
    e.CONTEXT,
    e.ORGANIZATION,
    e.API_UUID,
    e.reg_name,
    -- SuspensionLogic
    CASE 
        WHEN REGEXP_LIKE(e.EndpointConfig,   'suspend', 'i') THEN 'Suspension Enabled'
        WHEN REGEXP_LIKE(i.seq_content,      'suspend', 'i') THEN 'Suspension Enabled'
        WHEN REGEXP_LIKE(o.seq_content,      'suspend', 'i') THEN 'Suspension Enabled'
        ELSE 'Default Suspension'
    END AS SuspensionLogic,
    -- SuspensionSource: where exactly was suspend found
    CASE
        WHEN REGEXP_LIKE(e.EndpointConfig, 'suspend', 'i') AND
             REGEXP_LIKE(i.seq_content,    'suspend', 'i') AND
             REGEXP_LIKE(o.seq_content,    'suspend', 'i') THEN 'EndpointConfig, ' || e.inSequence || ', ' || e.outSequence
        WHEN REGEXP_LIKE(e.EndpointConfig, 'suspend', 'i') AND
             REGEXP_LIKE(i.seq_content,    'suspend', 'i') THEN 'EndpointConfig, ' || e.inSequence
        WHEN REGEXP_LIKE(e.EndpointConfig, 'suspend', 'i') AND
             REGEXP_LIKE(o.seq_content,    'suspend', 'i') THEN 'EndpointConfig, ' || e.outSequence
        WHEN REGEXP_LIKE(i.seq_content,    'suspend', 'i') AND
             REGEXP_LIKE(o.seq_content,    'suspend', 'i') THEN e.inSequence || ', ' || e.outSequence
        WHEN REGEXP_LIKE(e.EndpointConfig, 'suspend', 'i') THEN 'EndpointConfig'
        WHEN REGEXP_LIKE(i.seq_content,    'suspend', 'i') THEN e.inSequence
        WHEN REGEXP_LIKE(o.seq_content,    'suspend', 'i') THEN e.outSequence
        ELSE 'None'
    END AS SuspensionSource,
    e.reg_content_id,
    e.reg_path_value,
    e.EndpointConfig,
    e.inSequence,
    e.outSequence
FROM extracted e
-- Join in sequence file matching the inSequence name from API content
LEFT JOIN in_seq_content i
    ON i.reg_name = e.inSequence || '.xml'
-- Join out sequence file matching the outSequence name from API content
LEFT JOIN out_seq_content o
    ON o.reg_name = e.outSequence || '.xml'
;
