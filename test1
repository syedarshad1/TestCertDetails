SELECT 
  r.reg_content_id,
  r.reg_uuid,
  r.reg_name,
  r.reg_media_type,
  p.reg_path_value,
  r.reg_last_updated_time
FROM coct42_reg.reg_resource r
JOIN coct42_reg.reg_path p
  ON r.reg_path_id = p.reg_path_id
WHERE r.reg_name like '%Imaging_FCM_routing_flow_in_v3_update%'
  --AND p.reg_path_value LIKE '%Transfer%'
   --p.reg_path_value LIKE '%57acd129-630a-4455-9282-07080b848855%'
  --AND p.reg_path_value  LIKE '%Billpay%'
  --AND r.reg_tenant_id = 12
ORDER BY r.reg_last_updated_time DESC;
