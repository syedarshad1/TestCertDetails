SELECT 
    r.REG_PATH_ID,
    r.REG_FULL_PATH,
    r.REG_NAME,
    CAST(c.REG_CONTENT AS CLOB) AS SEQUENCE_CONTENT
FROM REG_RESOURCE r
LEFT JOIN REG_RESOURCE_CONTENT c ON r.REG_PATH_ID = c.REG_PATH_ID
WHERE r.REG_PATH_ID = 10543031
   OR r.REG_FULL_PATH = '/_system/governance/apimgt/customsequences/in/Imaging_FCM_routing_flow_in_v3_update.xml';
