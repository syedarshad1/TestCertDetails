WITH api_content AS (
    SELECT 
        a.API_NAME,
        a.CONTEXT,
        a.ORGANIZATION,
        a.API_UUID,
        r.reg_name,
        r.reg_content_id,
        p.reg_path_value,
        UTL_RAW.CAST_TO_VARCHAR2(HEXTORAW(DBMS_LOB.SUBSTR(c.reg_content_data, 2000, 1)))    AS content_p1,
        UTL_RAW.CAST_TO_VARCHAR2(HEXTORAW(DBMS_LOB.SUBSTR(c.reg_content_data, 2000, 2001))) AS content_p2,
        UTL_RAW.CAST_TO_VARCHAR2(HEXTORAW(DBMS_LOB.SUBSTR(c.reg_content_data, 2000, 4001))) AS content_p3
    FROM 
        COCT42_AM.AM_API a
        JOIN coct42_reg.reg_path p
            ON p.reg_path_value LIKE '%/_system/governance/apimgt/applicationdata/apis/' || a.API_UUID || '/%'
        JOIN coct42_reg.reg_resource r
            ON r.reg_path_id = p.reg_path_id
            AND r.reg_name = 'api'
            AND p.reg_path_value = (
                SELECT p2.reg_path_value
                FROM coct42_reg.reg_path p2
                JOIN coct42_reg.reg_resource r2
                    ON r2.reg_path_id = p2.reg_path_id
                    AND r2.reg_name = 'api'
                WHERE p2.reg_path_value LIKE '%/_system/governance/apimgt/applicationdata/apis/' || a.API_UUID || '/%'
                ORDER BY TO_NUMBER(REGEXP_SUBSTR(p2.reg_path_value, '\d+$')) DESC
                FETCH FIRST 1 ROW ONLY
            )
        JOIN coct42_reg.reg_content c ON c.reg_content_id = r.reg_content_id
    WHERE a.API_UUID = 'c6f3df68-f5da-4d89-979e-f163db878f0a'
),
extracted AS (
    SELECT
        API_NAME, CONTEXT, ORGANIZATION, API_UUID, reg_name, reg_content_id, reg_path_value,
        content_p1, content_p2, content_p3,
        COALESCE(
            REGEXP_SUBSTR(content_p1 || content_p2, '<endpointConfig>(.*?)</endpointConfig>', 1, 1, 'n', 1),
            REGEXP_SUBSTR(content_p2 || content_p3, '<endpointConfig>(.*?)</endpointConfig>', 1, 1, 'n', 1)
        ) AS EndpointConfig,
        COALESCE(
            REGEXP_SUBSTR(content_p1 || content_p2, '<inSequence>(.*?)</inSequence>',   1, 1, 'n', 1),
            REGEXP_SUBSTR(content_p2 || content_p3, '<inSequence>(.*?)</inSequence>',   1, 1, 'n', 1)
        ) AS inSequence,
        COALESCE(
            REGEXP_SUBSTR(content_p1 || content_p2, '<outSequence>(.*?)</outSequence>', 1, 1, 'n', 1),
            REGEXP_SUBSTR(content_p2 || content_p3, '<outSequence>(.*?)</outSequence>', 1, 1, 'n', 1)
        ) AS outSequence
    FROM api_content
),
-- Read inSequence XML chunks
in_seq_content AS (
    SELECT 
        r.reg_name,
        r.reg_content_id,
        UTL_RAW.CAST_TO_VARCHAR2(HEXTORAW(DBMS_LOB.SUBSTR(c.reg_content_data, 2000, 1)))    AS seq_p1,
        UTL_RAW.CAST_TO_VARCHAR2(HEXTORAW(DBMS_LOB.SUBSTR(c.reg_content_data, 2000, 2001))) AS seq_p2,
        UTL_RAW.CAST_TO_VARCHAR2(HEXTORAW(DBMS_LOB.SUBSTR(c.reg_content_data, 2000, 4001))) AS seq_p3
    FROM coct42_reg.reg_resource r
    JOIN coct42_reg.reg_path p    ON r.reg_path_id = p.reg_path_id
    JOIN coct42_reg.reg_content c ON c.reg_content_id = r.reg_content_id
    WHERE p.reg_path_value = '/_system/governance/apimgt/customsequences/in'
      AND r.reg_media_type  = 'application/vnd.wso2.sequence'
),
-- Read outSequence XML chunks
out_seq_content AS (
    SELECT 
        r.reg_name,
        r.reg_content_id,
        UTL_RAW.CAST_TO_VARCHAR2(HEXTORAW(DBMS_LOB.SUBSTR(c.reg_content_data, 2000, 1)))    AS seq_p1,
        UTL_RAW.CAST_TO_VARCHAR2(HEXTORAW(DBMS_LOB.SUBSTR(c.reg_content_data, 2000, 2001))) AS seq_p2,
        UTL_RAW.CAST_TO_VARCHAR2(HEXTORAW(DBMS_LOB.SUBSTR(c.reg_content_data, 2000, 4001))) AS seq_p3
    FROM coct42_reg.reg_resource r
    JOIN coct42_reg.reg_path p    ON r.reg_path_id = p.reg_path_id
    JOIN coct42_reg.reg_content c ON c.reg_content_id = r.reg_content_id
    WHERE p.reg_path_value = '/_system/governance/apimgt/customsequences/out'
      AND r.reg_media_type  = 'application/vnd.wso2.sequence'
),
-- Extract STATIC registry endpoint file reference from inSequence
-- Matches: conf:repository/resources/endpoints/some_file.xml  (no fn:concat = static)
in_seq_static_ref AS (
    SELECT
        i.reg_name AS seq_name,
        REGEXP_SUBSTR(
            i.seq_p1 || i.seq_p2,
            'conf:[^'']*?/endpoints/([^'']+\.xml)',
            1, 1, 'n', 1
        ) AS endpoint_filename,
        -- Flag if dynamic (fn:concat present near endpoint path)
        CASE 
            WHEN REGEXP_LIKE(i.seq_p1 || i.seq_p2, 'fn:concat[^>]*endpoint', 'i') THEN 'Y'
            WHEN REGEXP_LIKE(i.seq_p2 || i.seq_p3, 'fn:concat[^>]*endpoint', 'i') THEN 'Y'
            ELSE 'N'
        END AS is_dynamic,
        -- Flag if key-expression (runtime resolved)
        CASE 
            WHEN REGEXP_LIKE(i.seq_p1 || i.seq_p2, 'key-expression', 'i') THEN 'Y'
            WHEN REGEXP_LIKE(i.seq_p2 || i.seq_p3, 'key-expression', 'i') THEN 'Y'
            ELSE 'N'
        END AS is_key_expression
    FROM in_seq_content i
),
-- Extract STATIC registry endpoint file reference from outSequence
out_seq_static_ref AS (
    SELECT
        o.reg_name AS seq_name,
        REGEXP_SUBSTR(
            o.seq_p1 || o.seq_p2,
            'conf:[^'']*?/endpoints/([^'']+\.xml)',
            1, 1, 'n', 1
        ) AS endpoint_filename,
        CASE 
            WHEN REGEXP_LIKE(o.seq_p1 || o.seq_p2, 'fn:concat[^>]*endpoint', 'i') THEN 'Y'
            WHEN REGEXP_LIKE(o.seq_p2 || o.seq_p3, 'fn:concat[^>]*endpoint', 'i') THEN 'Y'
            ELSE 'N'
        END AS is_dynamic,
        CASE 
            WHEN REGEXP_LIKE(o.seq_p1 || o.seq_p2, 'key-expression', 'i') THEN 'Y'
            WHEN REGEXP_LIKE(o.seq_p2 || o.seq_p3, 'key-expression', 'i') THEN 'Y'
            ELSE 'N'
        END AS is_key_expression
    FROM out_seq_content o
),
-- Read static endpoint file content for inSequence reference
in_endpoint_content AS (
    SELECT
        iref.seq_name,
        iref.endpoint_filename,
        UTL_RAW.CAST_TO_VARCHAR2(HEXTORAW(DBMS_LOB.SUBSTR(c.reg_content_data, 2000, 1)))    AS ep_p1,
        UTL_RAW.CAST_TO_VARCHAR2(HEXTORAW(DBMS_LOB.SUBSTR(c.reg_content_data, 2000, 2001))) AS ep_p2,
        UTL_RAW.CAST_TO_VARCHAR2(HEXTORAW(DBMS_LOB.SUBSTR(c.reg_content_data, 2000, 4001))) AS ep_p3
    FROM in_seq_static_ref iref
    JOIN coct42_reg.reg_resource r  ON r.reg_name = iref.endpoint_filename
    JOIN coct42_reg.reg_path p      ON r.reg_path_id = p.reg_path_id
                                   AND p.reg_path_value LIKE '%/repository/resources/endpoints%'
    JOIN coct42_reg.reg_content c   ON c.reg_content_id = r.reg_content_id
    WHERE iref.endpoint_filename IS NOT NULL
      AND iref.is_dynamic = 'N'
),
-- Read static endpoint file content for outSequence reference
out_endpoint_content AS (
    SELECT
        oref.seq_name,
        oref.endpoint_filename,
        UTL_RAW.CAST_TO_VARCHAR2(HEXTORAW(DBMS_LOB.SUBSTR(c.reg_content_data, 2000, 1)))    AS ep_p1,
        UTL_RAW.CAST_TO_VARCHAR2(HEXTORAW(DBMS_LOB.SUBSTR(c.reg_content_data, 2000, 2001))) AS ep_p2,
        UTL_RAW.CAST_TO_VARCHAR2(HEXTORAW(DBMS_LOB.SUBSTR(c.reg_content_data, 2000, 4001))) AS ep_p3
    FROM out_seq_static_ref oref
    JOIN coct42_reg.reg_resource r  ON r.reg_name = oref.endpoint_filename
    JOIN coct42_reg.reg_path p      ON r.reg_path_id = p.reg_path_id
                                   AND p.reg_path_value LIKE '%/repository/resources/endpoints%'
    JOIN coct42_reg.reg_content c   ON c.reg_content_id = r.reg_content_id
    WHERE oref.endpoint_filename IS NOT NULL
      AND oref.is_dynamic = 'N'
)
SELECT
    e.API_NAME,
    e.CONTEXT,
    e.ORGANIZATION,
    e.API_UUID,
    e.reg_name,
    -- SuspensionLogic
    CASE
        WHEN REGEXP_LIKE(e.EndpointConfig,          'suspend', 'i') THEN 'Suspension Enabled'
        WHEN REGEXP_LIKE(i.seq_p1 || i.seq_p2,      'suspend', 'i') THEN 'Suspension Enabled'
        WHEN REGEXP_LIKE(i.seq_p2 || i.seq_p3,      'suspend', 'i') THEN 'Suspension Enabled'
        WHEN REGEXP_LIKE(o.seq_p1 || o.seq_p2,      'suspend', 'i') THEN 'Suspension Enabled'
        WHEN REGEXP_LIKE(o.seq_p2 || o.seq_p3,      'suspend', 'i') THEN 'Suspension Enabled'
        WHEN REGEXP_LIKE(ie.ep_p1 || ie.ep_p2,      'suspend', 'i') THEN 'Suspension Enabled'
        WHEN REGEXP_LIKE(ie.ep_p2 || ie.ep_p3,      'suspend', 'i') THEN 'Suspension Enabled'
        WHEN REGEXP_LIKE(oe.ep_p1 || oe.ep_p2,      'suspend', 'i') THEN 'Suspension Enabled'
        WHEN REGEXP_LIKE(oe.ep_p2 || oe.ep_p3,      'suspend', 'i') THEN 'Suspension Enabled'
        -- Dynamic endpoints - cannot determine
        WHEN isr.is_dynamic = 'Y' OR isr.is_key_expression = 'Y'   THEN 'Manual Check Required'
        WHEN osr.is_dynamic = 'Y' OR osr.is_key_expression = 'Y'   THEN 'Manual Check Required'
        ELSE 'Default Suspension'
    END AS SuspensionLogic,
    -- SuspensionSource: exactly where suspend found or why manual check needed
    CASE
        -- suspend found in endpointConfig
        WHEN REGEXP_LIKE(e.EndpointConfig, 'suspend', 'i')
            THEN 'EndpointConfig'
            || CASE WHEN REGEXP_LIKE(i.seq_p1||i.seq_p2,'suspend','i') OR REGEXP_LIKE(i.seq_p2||i.seq_p3,'suspend','i') THEN ', ' || e.inSequence ELSE '' END
            || CASE WHEN REGEXP_LIKE(o.seq_p1||o.seq_p2,'suspend','i') OR REGEXP_LIKE(o.seq_p2||o.seq_p3,'suspend','i') THEN ', ' || e.outSequence ELSE '' END
            || CASE WHEN REGEXP_LIKE(ie.ep_p1||ie.ep_p2,'suspend','i') OR REGEXP_LIKE(ie.ep_p2||ie.ep_p3,'suspend','i') THEN ', ' || ie.endpoint_filename ELSE '' END
            || CASE WHEN REGEXP_LIKE(oe.ep_p1||oe.ep_p2,'suspend','i') OR REGEXP_LIKE(oe.ep_p2||oe.ep_p3,'suspend','i') THEN ', ' || oe.endpoint_filename ELSE '' END
        -- suspend found in sequence directly
        WHEN REGEXP_LIKE(i.seq_p1||i.seq_p2,'suspend','i') OR REGEXP_LIKE(i.seq_p2||i.seq_p3,'suspend','i')
            THEN e.inSequence
            || CASE WHEN REGEXP_LIKE(o.seq_p1||o.seq_p2,'suspend','i') OR REGEXP_LIKE(o.seq_p2||o.seq_p3,'suspend','i') THEN ', ' || e.outSequence ELSE '' END
            || CASE WHEN REGEXP_LIKE(ie.ep_p1||ie.ep_p2,'suspend','i') OR REGEXP_LIKE(ie.ep_p2||ie.ep_p3,'suspend','i') THEN ', ' || ie.endpoint_filename ELSE '' END
            || CASE WHEN REGEXP_LIKE(oe.ep_p1||oe.ep_p2,'suspend','i') OR REGEXP_LIKE(oe.ep_p2||oe.ep_p3,'suspend','i') THEN ', ' || oe.endpoint_filename ELSE '' END
        WHEN REGEXP_LIKE(o.seq_p1||o.seq_p2,'suspend','i') OR REGEXP_LIKE(o.seq_p2||o.seq_p3,'suspend','i')
            THEN e.outSequence
            || CASE WHEN REGEXP_LIKE(ie.ep_p1||ie.ep_p2,'suspend','i') OR REGEXP_LIKE(ie.ep_p2||ie.ep_p3,'suspend','i') THEN ', ' || ie.endpoint_filename ELSE '' END
            || CASE WHEN REGEXP_LIKE(oe.ep_p1||oe.ep_p2,'suspend','i') OR REGEXP_LIKE(oe.ep_p2||oe.ep_p3,'suspend','i') THEN ', ' || oe.endpoint_filename ELSE '' END
        -- suspend found in static endpoint file
        WHEN REGEXP_LIKE(ie.ep_p1||ie.ep_p2,'suspend','i') OR REGEXP_LIKE(ie.ep_p2||ie.ep_p3,'suspend','i')
            THEN ie.endpoint_filename
            || CASE WHEN REGEXP_LIKE(oe.ep_p1||oe.ep_p2,'suspend','i') OR REGEXP_LIKE(oe.ep_p2||oe.ep_p3,'suspend','i') THEN ', ' || oe.endpoint_filename ELSE '' END
        WHEN REGEXP_LIKE(oe.ep_p1||oe.ep_p2,'suspend','i') OR REGEXP_LIKE(oe.ep_p2||oe.ep_p3,'suspend','i')
            THEN oe.endpoint_filename
        -- Dynamic endpoint - cannot determine automatically
        WHEN isr.is_dynamic = 'Y'
            THEN 'Dynamic endpoint in ' || e.inSequence || ' (fn:concat) - Manual Check Required'
        WHEN isr.is_key_expression = 'Y'
            THEN 'Runtime endpoint key-expression in ' || e.inSequence || ' - Manual Check Required'
        WHEN osr.is_dynamic = 'Y'
            THEN 'Dynamic endpoint in ' || e.outSequence || ' (fn:concat) - Manual Check Required'
        WHEN osr.is_key_expression = 'Y'
            THEN 'Runtime endpoint key-expression in ' || e.outSequence || ' - Manual Check Required'
        ELSE 'None'
    END AS SuspensionSource,
    e.reg_content_id,
    e.reg_path_value,
    e.EndpointConfig,
    e.inSequence,
    e.outSequence
FROM extracted e
LEFT JOIN in_seq_content       i   ON i.reg_name        = e.inSequence  || '.xml'
LEFT JOIN out_seq_content      o   ON o.reg_name        = e.outSequence || '.xml'
LEFT JOIN in_seq_static_ref    isr ON isr.seq_name      = e.inSequence  || '.xml'
LEFT JOIN out_seq_static_ref   osr ON osr.seq_name      = e.outSequence || '.xml'
LEFT JOIN in_endpoint_content  ie  ON ie.seq_name       = e.inSequence  || '.xml'
LEFT JOIN out_endpoint_content oe  ON oe.seq_name       = e.outSequence || '.xml'
;
