WITH api_sample AS (
    SELECT 
        a.API_NAME,
        a.API_UUID,
        UTL_RAW.CAST_TO_VARCHAR2(HEXTORAW(DBMS_LOB.SUBSTR(c.reg_content_data, 2000, 1)))    AS content_p1,
        UTL_RAW.CAST_TO_VARCHAR2(HEXTORAW(DBMS_LOB.SUBSTR(c.reg_content_data, 2000, 2001))) AS content_p2,
        UTL_RAW.CAST_TO_VARCHAR2(HEXTORAW(DBMS_LOB.SUBSTR(c.reg_content_data, 2000, 4001))) AS content_p3
    FROM 
        COCT42_AM.AM_API a
        JOIN coct42_reg.reg_path p
            ON p.reg_path_value LIKE '%/_system/governance/apimgt/applicationdata/apis/' || a.API_UUID || '/%'
        JOIN coct42_reg.reg_resource r
            ON r.reg_path_id = p.reg_path_id
            AND r.reg_name = 'api'
            AND p.reg_path_value = (
                SELECT p2.reg_path_value
                FROM coct42_reg.reg_path p2
                JOIN coct42_reg.reg_resource r2
                    ON r2.reg_path_id = p2.reg_path_id
                    AND r2.reg_name = 'api'
                WHERE p2.reg_path_value LIKE '%/_system/governance/apimgt/applicationdata/apis/' || a.API_UUID || '/%'
                ORDER BY TO_NUMBER(REGEXP_SUBSTR(p2.reg_path_value, '\d+$')) DESC
                FETCH FIRST 1 ROW ONLY
            )
        JOIN coct42_reg.reg_content c ON c.reg_content_id = r.reg_content_id
    FETCH FIRST 10 ROWS ONLY
),
extracted AS (
    SELECT
        API_NAME,
        API_UUID,
        COALESCE(
            REGEXP_SUBSTR(content_p1 || content_p2, '<inSequence>(.*?)</inSequence>',   1, 1, 'n', 1),
            REGEXP_SUBSTR(content_p2 || content_p3, '<inSequence>(.*?)</inSequence>',   1, 1, 'n', 1),
            'N/A'
        ) AS inSequence,
        COALESCE(
            REGEXP_SUBSTR(content_p1 || content_p2, '<outSequence>(.*?)</outSequence>', 1, 1, 'n', 1),
            REGEXP_SUBSTR(content_p2 || content_p3, '<outSequence>(.*?)</outSequence>', 1, 1, 'n', 1),
            'N/A'
        ) AS outSequence
    FROM api_sample
)
SELECT
    e.API_NAME,
    e.inSequence,
    e.outSequence,
    -- in sequence raw content up to 6000 bytes
    UTL_RAW.CAST_TO_VARCHAR2(HEXTORAW(DBMS_LOB.SUBSTR(ci.reg_content_data, 2000, 1)))    ||
    UTL_RAW.CAST_TO_VARCHAR2(HEXTORAW(DBMS_LOB.SUBSTR(ci.reg_content_data, 2000, 2001))) ||
    UTL_RAW.CAST_TO_VARCHAR2(HEXTORAW(DBMS_LOB.SUBSTR(ci.reg_content_data, 2000, 4001))) AS in_seq_raw_content,
    -- out sequence raw content up to 6000 bytes
    UTL_RAW.CAST_TO_VARCHAR2(HEXTORAW(DBMS_LOB.SUBSTR(co.reg_content_data, 2000, 1)))    ||
    UTL_RAW.CAST_TO_VARCHAR2(HEXTORAW(DBMS_LOB.SUBSTR(co.reg_content_data, 2000, 2001))) ||
    UTL_RAW.CAST_TO_VARCHAR2(HEXTORAW(DBMS_LOB.SUBSTR(co.reg_content_data, 2000, 4001))) AS out_seq_raw_content
FROM extracted e
LEFT JOIN coct42_reg.reg_resource ri ON ri.reg_name = e.inSequence  || '.xml'
LEFT JOIN coct42_reg.reg_content  ci ON ci.reg_content_id = ri.reg_content_id
LEFT JOIN coct42_reg.reg_resource ro ON ro.reg_name = e.outSequence || '.xml'
LEFT JOIN coct42_reg.reg_content  co ON co.reg_content_id = ro.reg_content_id
WHERE e.inSequence != 'N/A' 
   OR e.outSequence != 'N/A'
;
