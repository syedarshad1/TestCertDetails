-- Use UTL_RAW.CAST_TO_RAW to search, then extract safely
SELECT
  a.API_NAME,
  a.API_UUID,
  r.reg_content_id,
  p.reg_path_value,
  -- endpointConfig position
  DBMS_LOB.INSTR(c.reg_content_data,
    UTL_RAW.CAST_TO_RAW('endpointConfig'))  AS ep_config_pos,
  -- inSequence position  
  DBMS_LOB.INSTR(c.reg_content_data,
    UTL_RAW.CAST_TO_RAW('inSequence'))      AS in_seq_pos,
  -- suspend position
  DBMS_LOB.INSTR(c.reg_content_data,
    UTL_RAW.CAST_TO_RAW('suspend'))         AS suspend_pos,
  -- blob size
  DBMS_LOB.GETLENGTH(c.reg_content_data)   AS blob_size
FROM COCT42_AM.AM_API a
JOIN coct42_reg.reg_resource r
  ON r.reg_name = 'api'
JOIN coct42_reg.reg_path p
  ON p.reg_path_id = r.reg_path_id
  AND p.reg_path_value LIKE
      '/_system/governance/apimgt/applicationdata/apis/fd1b5417-eeea-4fef-b2df-c36affe0913e/%'
JOIN coct42_reg.reg_content c
  ON c.reg_content_id = r.reg_content_id
WHERE a.API_UUID = 'fd1b5417-eeea-4fef-b2df-c36affe0913e'
ORDER BY r.reg_content_id DESC
FETCH FIRST 1 ROWS ONLY;
