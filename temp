SELECT
  'EndpointConfig'               AS section,
  utl_raw.cast_to_varchar2(
    dbms_lob.substr(c.reg_content_data,
      -- length from endpointConfig to /endpointConfig
      DBMS_LOB.INSTR(c.reg_content_data,
        UTL_RAW.CAST_TO_RAW('/endpointConfig')) -
      DBMS_LOB.INSTR(c.reg_content_data,
        UTL_RAW.CAST_TO_RAW('endpointConfig')) + 17,
      -- start at endpointConfig position
      DBMS_LOB.INSTR(c.reg_content_data,
        UTL_RAW.CAST_TO_RAW('endpointConfig'))))
                                 AS content
FROM coct42_reg.reg_content c
WHERE c.reg_content_id = 15781073
UNION ALL
SELECT
  'SequenceFileName',
  utl_raw.cast_to_varchar2(
    dbms_lob.substr(c.reg_content_data,
      -- length from inSequence to /inSequence
      DBMS_LOB.INSTR(c.reg_content_data,
        UTL_RAW.CAST_TO_RAW('/inSequence')) -
      DBMS_LOB.INSTR(c.reg_content_data,
        UTL_RAW.CAST_TO_RAW('inSequence')) + 12,
      -- start at inSequence position
      DBMS_LOB.INSTR(c.reg_content_data,
        UTL_RAW.CAST_TO_RAW('inSequence'))))
                                 AS content
FROM coct42_reg.reg_content c
WHERE c.reg_content_id = 15781073;
