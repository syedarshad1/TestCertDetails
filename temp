index=dih sourcetype IN ("prd_dih_xmlsvr_usage_logs","prd_dih_xng_usage_logs") InboundURL!="ih-prd.prod.local*"
| eval RoutingType = mvindex(split(RoutingKey, "~"), 1),
       CertExpiryDateEpoch = strptime(CertExpiryDate, "%Y-%m-%d-%H:%M")
| where CertExpiryDateEpoch >= now() - 604800 
    AND CertExpiryDateEpoch <= now() + 2592000
| stats 
    count as TotalRequests_last7days
    min(CertExpiryDateEpoch) as CertExpiryDateEpoch
    values(CertHashCode) as CertHashCode
    values(SrcID) as SrcID
    values(RoutingID) as RoutingID
    values(RoutingKey) as RoutingKey
    values(RoutingType) as RoutingType
    values(InboundURL) as InboundURL
    values(sourcetype) as sourcetype
    by CertName
| eval CertExpiryDate = strftime(CertExpiryDateEpoch, "%Y-%m-%d %H:%M"),
       daystoexpire = round((CertExpiryDateEpoch - now()) / 86400, 0),
       RoutingType_lookup = mvindex(RoutingType, 0),
       SrcID_lookup = mvindex(SrcID, 0)
| lookup DIH_Companion_Contact_Details RoutingType AS RoutingType_lookup OUTPUT TeamName AS TeamName_rt EmailID AS EmailID_rt
| lookup DIH_Companion_Contact_Details SrcID AS SrcID_lookup OUTPUT TeamName AS TeamName_src EmailID AS EmailID_src
| eval TeamName = coalesce(TeamName_rt, TeamName_src, "Unknown"),
       EmailID = coalesce(EmailID_rt, EmailID_src, "syed.arshadali@fisglobal.com")
| sort CertExpiryDate
| table CertName CertExpiryDate daystoexpire TotalRequests_last7days SrcID RoutingType InboundURL CertHashCode sourcetype TeamName EmailID
| outputlookup dih_cert_expiry_temp.csv
| sendemail to=[| inputlookup dih_cert_expiry_temp.csv | stats values(EmailID) as emails | eval emails=mvjoin(emails,",") | return $emails]
    subject="DIH Certificate Expiry Alert"
    message="Hello Everyone,

This is an automated notification to inform you that one or more certificates used by DIH Gateway Users(FIS Internal App/External Clients) in the Production environment are expiring within the next 30 days.

Certificates expiring soon require timely action to prevent authentication failures and service outages. Please coordinate with the appropriate teams and stakeholders to complete the renewal process.

Required Actions
-------------------------------
Please contact the respective Client/Bank/Bank Vendor/Internal FIS application and request renewal of the expiring certificate.

Implementation Guidance
-------------------------------
A. When the Root/Intermediate Certificate is NOT Changing
   Proceed with the standard renewal process.Create a Change Request (CR). Assign an implementation task to the CTO Service Delivery team for deployment/add hash code.

B. When the Root Certificate IS Changing, FIS must explicitly trust the new root certificate. The LOB Team must submit a Change Request to:
	Akamizers Team / Load Balancer Team, and CTO Service Delivery

This ensures the new trust chain is properly installed across all required components

DIH Client Cert Dashboard
-------------------------------
Splunk Dashboard to Check Client Certificate Expiry using CertificateName, HashCode and filter by application.

