SELECT 
  r.reg_content_id,
  r.reg_name,
  p.reg_path_value,
  r.reg_last_updated_time,
  CASE
    WHEN DBMS_LOB.INSTR(c.reg_content_data,
           UTL_RAW.CAST_TO_RAW('suspend')) > 0
      THEN 'YES - has suspend'
    ELSE 'No suspend'
  END AS has_suspend
FROM coct42_reg.reg_resource r
JOIN coct42_reg.reg_path p
  ON r.reg_path_id = p.reg_path_id
JOIN coct42_reg.reg_content c
  ON c.reg_content_id = r.reg_content_id
WHERE r.reg_name LIKE '%endpoint%'
ORDER BY has_suspend DESC, r.reg_last_updated_time DESC;
