WITH reg_apis AS (
  SELECT
    REGEXP_SUBSTR(p.reg_path_value,
      '/apis/([0-9a-fA-F-]{36})/',
      1, 1, NULL, 1)             AS api_uuid,
    TO_NUMBER(REGEXP_SUBSTR(p.reg_path_value,
      '/apis/[0-9a-fA-F-]{36}/([0-9]+)',
      1, 1, NULL, 1))            AS rev,
    r.reg_content_id
  FROM   coct42_reg.reg_resource r
  JOIN   coct42_reg.reg_path p
    ON   p.reg_path_id = r.reg_path_id
  WHERE  r.reg_name = 'api'
    AND  p.reg_path_value LIKE
         '/_system/governance/apimgt/applicationdata/apis/%'
),
latest_rev AS (
  SELECT
    api_uuid,
    MAX(rev)                      AS latest_rev,
    MAX(reg_content_id) KEEP
      (DENSE_RANK LAST ORDER BY rev) AS reg_content_id
  FROM   reg_apis
  WHERE  api_uuid IS NOT NULL
  GROUP BY api_uuid
),
seq_resources AS (
  SELECT
    lr.api_uuid,
    REGEXP_SUBSTR(p.reg_path_value,
      '/(in|out|fault)$',
      1, 1, 'i', 1)             AS res_type,
    r.reg_name                   AS seq_name,
    utl_raw.cast_to_varchar2(
      dbms_lob.substr(c.reg_content_data,2000,1))    AS chunk1,
    utl_raw.cast_to_varchar2(
      dbms_lob.substr(c.reg_content_data,2000,2001))  AS chunk2,
    utl_raw.cast_to_varchar2(
      dbms_lob.substr(c.reg_content_data,2000,4001))  AS chunk3
  FROM   latest_rev lr
  JOIN   coct42_reg.reg_path p
    ON   p.reg_path_value IN (
           '/_system/governance/apimgt/applicationdata/apis/'
             || lr.api_uuid || '/' || lr.latest_rev || '/in',
           '/_system/governance/apimgt/applicationdata/apis/'
             || lr.api_uuid || '/' || lr.latest_rev || '/out',
           '/_system/governance/apimgt/applicationdata/apis/'
             || lr.api_uuid || '/' || lr.latest_rev || '/fault'
         )
  JOIN   coct42_reg.reg_resource r
    ON   r.reg_path_id    = p.reg_path_id
    AND  r.reg_content_id IS NOT NULL
  JOIN   coct42_reg.reg_content c
    ON   c.reg_content_id = r.reg_content_id
),
seq_analysis AS (
  SELECT
    api_uuid, res_type, seq_name,
    CASE
      WHEN INSTR(UPPER(chunk1),'SUSPEND')>0
        OR   INSTR(UPPER(chunk2),'SUSPEND')>0
        OR   INSTR(UPPER(chunk3),'SUSPEND')>0
        THEN 1 ELSE 0
    END                           AS has_suspend,
    CASE
      WHEN INSTR(chunk1,'suspendDuration'||CHR(34)||':'||CHR(34)||'0'||CHR(34))>0
        OR   INSTR(chunk2,'suspendDuration'||CHR(34)||':'||CHR(34)||'0'||CHR(34))>0
        OR   INSTR(chunk3,'suspendDuration'||CHR(34)||':'||CHR(34)||'0'||CHR(34))>0
        OR   INSTR(chunk1,'suspendDuration'||CHR(62)||'0'||CHR(60))>0
        OR   INSTR(chunk2,'suspendDuration'||CHR(62)||'0'||CHR(60))>0
        OR   INSTR(chunk3,'suspendDuration'||CHR(62)||'0'||CHR(60))>0
        THEN 1 ELSE 0
    END                           AS suspend_dur_zero,
    CASE
      WHEN INSTR(chunk1,'suspendMaxDuration'||CHR(34)||':'||CHR(34)||'0'||CHR(34))>0
        OR   INSTR(chunk2,'suspendMaxDuration'||CHR(34)||':'||CHR(34)||'0'||CHR(34))>0
        OR   INSTR(chunk3,'suspendMaxDuration'||CHR(34)||':'||CHR(34)||'0'||CHR(34))>0
        OR   INSTR(chunk1,'suspendMaxDuration'||CHR(62)||'0'||CHR(60))>0
        OR   INSTR(chunk2,'suspendMaxDuration'||CHR(62)||'0'||CHR(60))>0
        OR   INSTR(chunk3,'suspendMaxDuration'||CHR(62)||'0'||CHR(60))>0
        THEN 1 ELSE 0
    END                           AS suspend_max_zero,
    CASE
      WHEN INSTR(chunk1,CHR(34)||'-1'||CHR(34))>0
        OR   INSTR(chunk2,CHR(34)||'-1'||CHR(34))>0
        OR   INSTR(chunk3,CHR(34)||'-1'||CHR(34))>0
        OR   INSTR(chunk1,'errorCodes'||CHR(62)||'-1'||CHR(60))>0
        OR   INSTR(chunk2,'errorCodes'||CHR(62)||'-1'||CHR(60))>0
        OR   INSTR(chunk3,'errorCodes'||CHR(62)||'-1'||CHR(60))>0
        THEN 1 ELSE 0
    END                           AS error_code_minus1,
    CASE
      WHEN INSTR(chunk1,'suspendErrorCode')>0
        OR   INSTR(chunk2,'suspendErrorCode')>0
        OR   INSTR(chunk3,'suspendErrorCode')>0
        THEN 1 ELSE 0
    END                           AS has_error_code,
    CASE
      WHEN INSTR(chunk1,'endpointConfig')>0
        THEN REPLACE(REPLACE(REPLACE(REPLACE(
               SUBSTR(chunk1,
                 INSTR(chunk1,CHR(60)||'endpointConfig'||CHR(62)),
                 INSTR(chunk1,CHR(60)||'/endpointConfig'||CHR(62))-
                 INSTR(chunk1,CHR(60)||'endpointConfig'||CHR(62))+17),
             CHR(10),''),CHR(13),''),CHR(9),''),CHR(34),'')
      WHEN INSTR(chunk2,'endpointConfig')>0
        THEN REPLACE(REPLACE(REPLACE(REPLACE(
               SUBSTR(chunk2,
                 INSTR(chunk2,CHR(60)||'endpointConfig'||CHR(62)),
                 INSTR(chunk2,CHR(60)||'/endpointConfig'||CHR(62))-
                 INSTR(chunk2,CHR(60)||'endpointConfig'||CHR(62))+17),
             CHR(10),''),CHR(13),''),CHR(9),''),CHR(34),'')
      ELSE NULL
    END                           AS seq_endpoint_config,
    CASE
      WHEN INSTR(chunk1,'actionDuration'||CHR(62))>0
        THEN SUBSTR(chunk1,
               INSTR(chunk1,'actionDuration'||CHR(62))+15,
               INSTR(chunk1,CHR(60),
                 INSTR(chunk1,'actionDuration'||CHR(62))+15)-
               INSTR(chunk1,'actionDuration'||CHR(62))-15)
      WHEN INSTR(chunk1,'actionDuration'||CHR(34)||':'||CHR(34))>0
        THEN SUBSTR(chunk1,
               INSTR(chunk1,'actionDuration'||CHR(34)||':'||CHR(34))+17,
               INSTR(chunk1,CHR(34),
                 INSTR(chunk1,'actionDuration'||CHR(34)||':'||CHR(34))+17)-
               INSTR(chunk1,'actionDuration'||CHR(34)||':'||CHR(34))-17)
      WHEN INSTR(chunk2,'actionDuration'||CHR(62))>0
        THEN SUBSTR(chunk2,
               INSTR(chunk2,'actionDuration'||CHR(62))+15,
               INSTR(chunk2,CHR(60),
                 INSTR(chunk2,'actionDuration'||CHR(62))+15)-
               INSTR(chunk2,'actionDuration'||CHR(62))-15)
      WHEN INSTR(chunk2,'actionDuration'||CHR(34)||':'||CHR(34))>0
        THEN SUBSTR(chunk2,
               INSTR(chunk2,'actionDuration'||CHR(34)||':'||CHR(34))+17,
               INSTR(chunk2,CHR(34),
                 INSTR(chunk2,'actionDuration'||CHR(34)||':'||CHR(34))+17)-
               INSTR(chunk2,'actionDuration'||CHR(34)||':'||CHR(34))-17)
      WHEN INSTR(chunk3,'actionDuration'||CHR(62))>0
        THEN SUBSTR(chunk3,
               INSTR(chunk3,'actionDuration'||CHR(62))+15,
               INSTR(chunk3,CHR(60),
                 INSTR(chunk3,'actionDuration'||CHR(62))+15)-
               INSTR(chunk3,'actionDuration'||CHR(62))-15)
      WHEN INSTR(chunk3,'actionDuration'||CHR(34)||':'||CHR(34))>0
        THEN SUBSTR(chunk3,
               INSTR(chunk3,'actionDuration'||CHR(34)||':'||CHR(34))+17,
               INSTR(chunk3,CHR(34),
                 INSTR(chunk3,'actionDuration'||CHR(34)||':'||CHR(34))+17)-
               INSTR(chunk3,'actionDuration'||CHR(34)||':'||CHR(34))-17)
      ELSE NULL
    END                           AS action_duration
  FROM   seq_resources
),
seq_suspend AS (
  SELECT
    api_uuid,
    MAX(seq_name) KEEP
      (DENSE_RANK FIRST ORDER BY
        CASE res_type WHEN 'in' THEN 1
                      WHEN 'out' THEN 2
                      WHEN 'fault' THEN 3 END,
        has_suspend DESC)         AS seq_name,
    MAX(has_suspend)              AS has_suspend,
    MAX(suspend_dur_zero) KEEP
      (DENSE_RANK FIRST ORDER BY
        CASE res_type WHEN 'in' THEN 1
                      WHEN 'out' THEN 2
                      WHEN 'fault' THEN 3 END,
        has_suspend DESC)         AS suspend_dur_zero,
    MAX(suspend_max_zero) KEEP
      (DENSE_RANK FIRST ORDER BY
        CASE res_type WHEN 'in' THEN 1
                      WHEN 'out' THEN 2
                      WHEN 'fault' THEN 3 END,
        has_suspend DESC)         AS suspend_max_zero,
    MAX(error_code_minus1) KEEP
      (DENSE_RANK FIRST ORDER BY
        CASE res_type WHEN 'in' THEN 1
                      WHEN 'out' THEN 2
                      WHEN 'fault' THEN 3 END,
        has_suspend DESC)         AS error_code_minus1,
    MAX(has_error_code) KEEP
      (DENSE_RANK FIRST ORDER BY
        CASE res_type WHEN 'in' THEN 1
                      WHEN 'out' THEN 2
                      WHEN 'fault' THEN 3 END,
        has_suspend DESC)         AS has_error_code,
    MAX(seq_endpoint_config) KEEP
      (DENSE_RANK FIRST ORDER BY
        CASE res_type WHEN 'in' THEN 1
                      WHEN 'out' THEN 2
                      WHEN 'fault' THEN 3 END,
        CASE WHEN seq_endpoint_config IS NOT NULL
          THEN 0 ELSE 1 END)      AS seq_endpoint_config,
    MAX(action_duration) KEEP
      (DENSE_RANK FIRST ORDER BY
        CASE res_type WHEN 'in' THEN 1
                      WHEN 'out' THEN 2
                      WHEN 'fault' THEN 3 END,
        CASE WHEN action_duration IS NOT NULL
          THEN 0 ELSE 1 END)      AS seq_action_duration
  FROM   seq_analysis
  GROUP BY api_uuid
)
SELECT COUNT(*) FROM seq_suspend;
