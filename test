WITH reg_apis AS (
  SELECT
    REGEXP_SUBSTR(p.reg_path_value,
      '/apis/([0-9a-fA-F-]{36})/',
      1, 1, NULL, 1)             AS api_uuid,
    TO_NUMBER(REGEXP_SUBSTR(p.reg_path_value,
      '/apis/[0-9a-fA-F-]{36}/([0-9]+)',
      1, 1, NULL, 1))            AS rev,
    r.reg_content_id
  FROM   coct42_reg.reg_resource r
  JOIN   coct42_reg.reg_path p
    ON   p.reg_path_id = r.reg_path_id
  WHERE  r.reg_name = 'api'
    AND  p.reg_path_value LIKE
         '/_system/governance/apimgt/applicationdata/apis/%'
),
latest_rev AS (
  SELECT
    api_uuid,
    MAX(reg_content_id) KEEP
      (DENSE_RANK LAST ORDER BY rev) AS reg_content_id
  FROM   reg_apis
  WHERE  api_uuid IS NOT NULL
  GROUP BY api_uuid
),
api_blob AS (
  -- Extract inSequence and outSequence from API blob
  SELECT
    lr.api_uuid,
    REGEXP_SUBSTR(
      TO_CLOB(utl_raw.cast_to_varchar2(
        dbms_lob.substr(c.reg_content_data, 2000, 1)))  ||
      TO_CLOB(utl_raw.cast_to_varchar2(
        dbms_lob.substr(c.reg_content_data, 2000, 2001)))||
      TO_CLOB(utl_raw.cast_to_varchar2(
        dbms_lob.substr(c.reg_content_data, 2000, 4001))),
      '<inSequence>([^<]+)</inSequence>',
      1, 1, 'n', 1)               AS in_seq_from_blob,
    REGEXP_SUBSTR(
      TO_CLOB(utl_raw.cast_to_varchar2(
        dbms_lob.substr(c.reg_content_data, 2000, 1)))  ||
      TO_CLOB(utl_raw.cast_to_varchar2(
        dbms_lob.substr(c.reg_content_data, 2000, 2001)))||
      TO_CLOB(utl_raw.cast_to_varchar2(
        dbms_lob.substr(c.reg_content_data, 2000, 4001))),
      '<outSequence>([^<]+)</outSequence>',
      1, 1, 'n', 1)               AS out_seq_from_blob
  FROM   latest_rev lr
  LEFT JOIN coct42_reg.reg_content c
    ON   c.reg_content_id = lr.reg_content_id
),
provider_seq AS (
  -- Provider path in/out sequences
  SELECT
    REGEXP_SUBSTR(p.reg_path_value,
      '/provider/[^/]+/([^/]+)/[^/]+/(in|out)$',
      1, 1, 'i', 1)             AS api_name,
    REGEXP_SUBSTR(p.reg_path_value,
      '/provider/[^/]+/[^/]+/([^/]+)/(in|out)$',
      1, 1, 'i', 1)             AS api_version,
    REGEXP_SUBSTR(p.reg_path_value,
      '/(in|out)$',
      1, 1, 'i', 1)             AS seq_type,
    MAX(r.reg_name) KEEP
      (DENSE_RANK LAST ORDER BY r.reg_last_updated_time)
      AS seq_name
  FROM   coct42_reg.reg_resource r
  JOIN   coct42_reg.reg_path p
    ON   p.reg_path_id = r.reg_path_id
  WHERE  (
           p.reg_path_value LIKE
             '/_system/governance/apimgt/applicationdata/provider/%/in'
        OR p.reg_path_value LIKE
             '/_system/governance/apimgt/applicationdata/provider/%/out'
         )
    AND  r.reg_name       IS NOT NULL
    AND  r.reg_content_id IS NOT NULL
  GROUP BY
    REGEXP_SUBSTR(p.reg_path_value,
      '/provider/[^/]+/([^/]+)/[^/]+/(in|out)$',
      1, 1, 'i', 1),
    REGEXP_SUBSTR(p.reg_path_value,
      '/provider/[^/]+/[^/]+/([^/]+)/(in|out)$',
      1, 1, 'i', 1),
    REGEXP_SUBSTR(p.reg_path_value,
      '/(in|out)$',
      1, 1, 'i', 1)
)
SELECT
  a.API_NAME,
  a.API_VERSION,
  a.CONTEXT,
  a.STATUS,
  a.ORGANIZATION                  AS TENANT,
  a.UPDATED_TIME,
  -- In sequence
  COALESCE(
    pin.seq_name,
    ab.in_seq_from_blob)           AS in_sequence_name,
  CASE
    WHEN pin.seq_name        IS NOT NULL THEN 'Provider path'
    WHEN ab.in_seq_from_blob IS NOT NULL THEN 'Global (API blob tag)'
    ELSE 'None'
  END                             AS in_sequence_source,
  -- Out sequence
  COALESCE(
    pout.seq_name,
    ab.out_seq_from_blob)          AS out_sequence_name,
  CASE
    WHEN pout.seq_name        IS NOT NULL THEN 'Provider path'
    WHEN ab.out_seq_from_blob IS NOT NULL THEN 'Global (API blob tag)'
    ELSE 'None'
  END                             AS out_sequence_source
FROM   COCT42_AM.AM_API a
LEFT JOIN api_blob ab
  ON   ab.api_uuid        = a.API_UUID
LEFT JOIN provider_seq pin
  ON   pin.api_name       = a.API_NAME
  AND  pin.api_version    = a.API_VERSION
  AND  pin.seq_type       = 'in'
LEFT JOIN provider_seq pout
  ON   pout.api_name      = a.API_NAME
  AND  pout.api_version   = a.API_VERSION
  AND  pout.seq_type      = 'out'
ORDER BY in_sequence_source, a.ORGANIZATION, a.API_NAME, a.API_VERSION;
