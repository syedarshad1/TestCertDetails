-- Decode aaa_als_seq_in.xml to see URL, timeout, suspend
SELECT
  r.reg_name,
  r.reg_content_id,
  REPLACE(REPLACE(REPLACE(
    utl_raw.cast_to_varchar2(
      dbms_lob.substr(c.reg_content_data, 2000, 1)),
  CHR(10),' '),CHR(13),''),CHR(9),' ') AS seq_content
FROM   coct42_reg.reg_resource r
JOIN   coct42_reg.reg_path p
  ON   p.reg_path_id = r.reg_path_id
JOIN   coct42_reg.reg_content c
  ON   c.reg_content_id = r.reg_content_id
WHERE  r.reg_name = 'aaa_als_seq_in.xml'
  AND  p.reg_path_value LIKE '%customsequences/in%'
ORDER BY r.reg_last_updated_time DESC
FETCH FIRST 1 ROWS ONLY;
