-- Check provider path (API specific)
SELECT
  'Provider path'              AS location,
  r.reg_name,
  r.reg_content_id,
  p.reg_path_value,
  r.reg_last_updated_time
FROM   coct42_reg.reg_resource r
JOIN   coct42_reg.reg_path p
  ON   p.reg_path_id = r.reg_path_id
WHERE  p.reg_path_value LIKE
         '/_system/governance/apimgt/applicationdata/provider/%/PaymentOrderManagement/5.1.4/%'

UNION ALL

-- Check global customsequences path
SELECT
  'Global customsequences'     AS location,
  r.reg_name,
  r.reg_content_id,
  p.reg_path_value,
  r.reg_last_updated_time
FROM   coct42_reg.reg_resource r
JOIN   coct42_reg.reg_path p
  ON   p.reg_path_id = r.reg_path_id
WHERE  p.reg_path_value LIKE
         '/_system/governance/apimgt/customsequences/%'
  AND  r.reg_name LIKE '%pom%'

ORDER BY location, reg_path_value, reg_name;
