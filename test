WITH chunks AS (
  -- Read each chunk separately — no concatenation
  SELECT
    r.reg_name,
    c.reg_content_id,
    utl_raw.cast_to_varchar2(
      dbms_lob.substr(c.reg_content_data, 2000, 1))     AS chunk1,
    utl_raw.cast_to_varchar2(
      dbms_lob.substr(c.reg_content_data, 2000, 2001))   AS chunk2,
    utl_raw.cast_to_varchar2(
      dbms_lob.substr(c.reg_content_data, 2000, 4001))   AS chunk3,
    utl_raw.cast_to_varchar2(
      dbms_lob.substr(c.reg_content_data, 2000, 6001))   AS chunk4
  FROM   coct42_reg.reg_content c
  JOIN   coct42_reg.reg_resource r
    ON   r.reg_content_id = c.reg_content_id
  WHERE  c.reg_content_id IN (15809609, 15809613)
)
SELECT
  reg_name,
  -- Backend URL — check each chunk
  CASE
    WHEN INSTR(chunk1, 'uri-template="') > 0
      THEN SUBSTR(chunk1,
             INSTR(chunk1, 'uri-template="') + 14,
             INSTR(chunk1, '"',
               INSTR(chunk1, 'uri-template="') + 14) -
             INSTR(chunk1, 'uri-template="') - 14)
    WHEN INSTR(chunk2, 'uri-template="') > 0
      THEN SUBSTR(chunk2,
             INSTR(chunk2, 'uri-template="') + 14,
             INSTR(chunk2, '"',
               INSTR(chunk2, 'uri-template="') + 14) -
             INSTR(chunk2, 'uri-template="') - 14)
    ELSE 'Dynamic or not set'
  END                             AS backend_url,
  -- Timeout
  CASE
    WHEN INSTR(chunk1, '<duration>') > 0
      THEN SUBSTR(chunk1,
             INSTR(chunk1, '<duration>') + 10,
             INSTR(chunk1, '</duration>') -
             INSTR(chunk1, '<duration>') - 10)
    WHEN INSTR(chunk2, '<duration>') > 0
      THEN SUBSTR(chunk2,
             INSTR(chunk2, '<duration>') + 10,
             INSTR(chunk2, '</duration>') -
             INSTR(chunk2, '<duration>') - 10)
    ELSE 'Not set'
  END                             AS timeout_ms,
  -- Suspend — check which chunk has it
  CASE
    WHEN INSTR(UPPER(chunk1), 'SUSPEND') > 0
      THEN SUBSTR(chunk1,
             GREATEST(INSTR(UPPER(chunk1), 'SUSPEND') - 30, 1), 300)
    WHEN INSTR(UPPER(chunk2), 'SUSPEND') > 0
      THEN SUBSTR(chunk2,
             GREATEST(INSTR(UPPER(chunk2), 'SUSPEND') - 30, 1), 300)
    WHEN INSTR(UPPER(chunk3), 'SUSPEND') > 0
      THEN SUBSTR(chunk3,
             GREATEST(INSTR(UPPER(chunk3), 'SUSPEND') - 30, 1), 300)
    ELSE 'No suspend logic'
  END                             AS suspend_context,
  -- Internal sequence calls
  CASE
    WHEN INSTR(chunk1, 'sequence key="') > 0
      THEN SUBSTR(chunk1,
             INSTR(chunk1, 'sequence key="') + 14,
             INSTR(chunk1, '"',
               INSTR(chunk1, 'sequence key="') + 14) -
             INSTR(chunk1, 'sequence key="') - 14)
    WHEN INSTR(chunk2, 'sequence key="') > 0
      THEN SUBSTR(chunk2,
             INSTR(chunk2, 'sequence key="') + 14,
             INSTR(chunk2, '"',
               INSTR(chunk2, 'sequence key="') + 14) -
             INSTR(chunk2, 'sequence key="') - 14)
    WHEN INSTR(chunk1, 'send receive="') > 0
      THEN SUBSTR(chunk1,
             INSTR(chunk1, 'send receive="') + 14,
             INSTR(chunk1, '"',
               INSTR(chunk1, 'send receive="') + 14) -
             INSTR(chunk1, 'send receive="') - 14)
    ELSE 'No internal sequence calls'
  END                             AS calls_sequence
FROM   chunks
ORDER BY reg_name;
