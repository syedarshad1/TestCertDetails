SELECT
  r.reg_name,
  r.reg_content_id,
  p.reg_path_value,
  r.reg_last_updated_time
FROM   coct42_reg.reg_resource r
JOIN   coct42_reg.reg_path p
  ON   p.reg_path_id = r.reg_path_id
WHERE  r.reg_name IN (
         'soap_endpoint_seq_rbc_in',
         'soap_endpoint_seq_rbc_out'
       )
ORDER BY r.reg_name;
