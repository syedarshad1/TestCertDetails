SELECT
    API_ID,
    API_UUID,
    API_PROVIDER,
    API_NAME,
    API_VERSION,
    CONTEXT,
    ORGANIZATION,
    STATUS,
    UPDATED_TIME
FROM   COCT42_AM.AM_API
ORDER BY API_NAME, API_VERSION;

SELECT
    API_ID,
    API_UUID,
    API_PROVIDER,
    API_NAME,
    API_VERSION,
    CONTEXT,
    ORGANIZATION,
    STATUS,
    UPDATED_BY,
    UPDATED_TIME
FROM   COCT42_AM.AM_API
ORDER BY UPDATED_TIME DESC;  -- most recently modified first
