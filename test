  -- ENDPOINT_CONFIG: seq first then api blob — both VARCHAR2
  COALESCE(
    SUBSTR(ss.seq_endpoint_config, 1, 4000),
    SUBSTR(ec.api_endpoint_config, 1, 4000)
  )                               AS ENDPOINT_CONFIG,
  -- TIMEOUT: seq first then api blob then global default
  COALESCE(
    SUBSTR(ss.seq_action_duration, 1, 100),
    SUBSTR(ec.api_action_duration, 1, 100),
    '120000ms (synapse global default)'
  )                               AS TIMEOUT_MS
