-- Get Reg_Content_ID to View the API Configuration/Swagger Details --
SELECT 
  r.reg_content_id,
  r.reg_uuid,
  r.reg_name,
  r.reg_media_type,
  p.reg_path_value,
  r.reg_last_updated_time
FROM coct42_reg.reg_resource r
JOIN coct42_reg.reg_path p
  ON r.reg_path_id = p.reg_path_id
WHERE r.reg_name like  '%pay%'
     AND p.reg_path_value LIKE '%/_system/config/%'
  --AND p.reg_path_value LIKE '%6f8d9aa2-077e-4b7a-9106-ba78d013dc5e%'
   --r.reg_name like  '%gs_als_loan_affiliate_add_REST%'
  --AND p.reg_path_value  LIKE '%Billpay%'
  --AND r.reg_tenant_id = 12
ORDER BY r.reg_last_updated_time DESC;

-- Tenant based list of API uuid --
SELECT
  api_uuid,
  MAX(rev) AS latest_revision,
  MAX(reg_content_id) KEEP (DENSE_RANK LAST ORDER BY rev) AS reg_content_id
FROM (
  SELECT
    REGEXP_SUBSTR(p.reg_path_value,
                  '/apis/([0-9a-fA-F-]{36})/',
                  1, 1, NULL, 1) AS api_uuid,
    TO_NUMBER(REGEXP_SUBSTR(p.reg_path_value,
                            '/apis/[0-9a-fA-F-]{36}/([0-9]+)',
                            1, 1, NULL, 1)) AS rev,
    r.reg_content_id
  FROM coct42_reg.reg_resource r
  JOIN coct42_reg.reg_path p
    ON p.reg_path_id = r.reg_path_id
  WHERE r.reg_tenant_id = 12
    AND r.reg_name = 'api'
    AND p.reg_path_value LIKE '/_system/governance/apimgt/applicationdata/apis/%'
)
WHERE api_uuid IS NOT NULL
GROUP BY api_uuid
ORDER BY api_uuid;

