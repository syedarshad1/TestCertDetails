WITH target_apis AS (
  SELECT API_UUID, API_NAME, API_VERSION
  FROM   COCT42_AM.AM_API
  WHERE  API_NAME    = 'PaymentOrderManagement'
    AND  API_VERSION IN ('5.1.4', '1.1')
),
latest_rev AS (
  SELECT
    t.API_NAME,
    t.API_VERSION,
    MAX(r.reg_content_id) AS reg_content_id
  FROM   target_apis t
  JOIN   coct42_reg.reg_resource r
    ON   r.reg_name = 'api'
  JOIN   coct42_reg.reg_path p
    ON   p.reg_path_id  = r.reg_path_id
    AND  p.reg_path_value LIKE
           '/_system/governance/apimgt/applicationdata/apis/%'
    AND  p.reg_path_value LIKE '%' || t.API_UUID || '%'
  GROUP BY t.API_NAME, t.API_VERSION
),
api_blob AS (
  -- Decode blob into VARCHAR2 (first 4000 chars covers sequence tags)
  -- Use SUBSTR on decoded text to extract inSequence/outSequence
  SELECT
    lr.API_NAME,
    lr.API_VERSION,
    utl_raw.cast_to_varchar2(
      dbms_lob.substr(c.reg_content_data, 2000, 1)) ||
    utl_raw.cast_to_varchar2(
      dbms_lob.substr(c.reg_content_data, 2000, 2001)) AS blob_txt
  FROM   latest_rev lr
  JOIN   coct42_reg.reg_content c
    ON   c.reg_content_id = lr.reg_content_id
),
api_seq AS (
  -- Extract inSequence and outSequence from VARCHAR2 blob
  SELECT
    API_NAME,
    API_VERSION,
    -- inSequence: text between tags
    CASE
      WHEN INSTR(blob_txt, '<inSequence>') > 0
       AND INSTR(blob_txt, '</inSequence>') > 0
        THEN TRIM(SUBSTR(
               blob_txt,
               INSTR(blob_txt, '<inSequence>') + 12,
               INSTR(blob_txt, '</inSequence>')
                 - INSTR(blob_txt, '<inSequence>') - 12
             ))
    END                           AS in_seq_from_blob,
    -- outSequence: text between tags
    CASE
      WHEN INSTR(blob_txt, '<outSequence>') > 0
       AND INSTR(blob_txt, '</outSequence>') > 0
        THEN TRIM(SUBSTR(
               blob_txt,
               INSTR(blob_txt, '<outSequence>') + 13,
               INSTR(blob_txt, '</outSequence>')
                 - INSTR(blob_txt, '<outSequence>') - 13
             ))
    END                           AS out_seq_from_blob
  FROM   api_blob
),
provider_seq AS (
  SELECT
    REGEXP_SUBSTR(p.reg_path_value,
      '/provider/[^/]+/([^/]+)/[^/]+/(in|out)$',
      1, 1, 'i', 1)             AS api_name,
    REGEXP_SUBSTR(p.reg_path_value,
      '/provider/[^/]+/[^/]+/([^/]+)/(in|out)$',
      1, 1, 'i', 1)             AS api_version,
    REGEXP_SUBSTR(p.reg_path_value,
      '/(in|out)$',
      1, 1, 'i', 1)             AS seq_type,
    MAX(r.reg_name) KEEP
      (DENSE_RANK LAST ORDER BY r.reg_last_updated_time)
      AS seq_name
  FROM   coct42_reg.reg_resource r
  JOIN   coct42_reg.reg_path p
    ON   p.reg_path_id = r.reg_path_id
  WHERE  (
           p.reg_path_value LIKE '%/PaymentOrderManagement/5.1.4/in'
        OR p.reg_path_value LIKE '%/PaymentOrderManagement/5.1.4/out'
        OR p.reg_path_value LIKE '%/PaymentOrderManagement/1.1/in'
        OR p.reg_path_value LIKE '%/PaymentOrderManagement/1.1/out'
         )
    AND  r.reg_name       IS NOT NULL
    AND  r.reg_content_id IS NOT NULL
  GROUP BY
    REGEXP_SUBSTR(p.reg_path_value,
      '/provider/[^/]+/([^/]+)/[^/]+/(in|out)$',
      1, 1, 'i', 1),
    REGEXP_SUBSTR(p.reg_path_value,
      '/provider/[^/]+/[^/]+/([^/]+)/(in|out)$',
      1, 1, 'i', 1),
    REGEXP_SUBSTR(p.reg_path_value,
      '/(in|out)$',
      1, 1, 'i', 1)
)
SELECT
  s.API_NAME,
  s.API_VERSION,
  COALESCE(pin.seq_name,
           NULLIF(s.in_seq_from_blob, ''),
           'None')               AS in_sequence_name,
  CASE
    WHEN pin.seq_name              IS NOT NULL THEN 'Provider path'
    WHEN NULLIF(s.in_seq_from_blob,  '') IS NOT NULL THEN 'Global (API blob tag)'
    ELSE 'None'
  END                             AS in_sequence_source,
  COALESCE(pout.seq_name,
           NULLIF(s.out_seq_from_blob, ''),
           'None')               AS out_sequence_name,
  CASE
    WHEN pout.seq_name             IS NOT NULL THEN 'Provider path'
    WHEN NULLIF(s.out_seq_from_blob, '') IS NOT NULL THEN 'Global (API blob tag)'
    ELSE 'None'
  END                             AS out_sequence_source
FROM   api_seq s
LEFT JOIN provider_seq pin
  ON   pin.api_name    = s.API_NAME
  AND  pin.api_version = s.API_VERSION
  AND  pin.seq_type    = 'in'
LEFT JOIN provider_seq pout
  ON   pout.api_name    = s.API_NAME
  AND  pout.api_version = s.API_VERSION
  AND  pout.seq_type    = 'out'
ORDER BY s.API_VERSION;
