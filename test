-- See all paths and resources stored under this UUID
SELECT
  r.reg_name,
  r.reg_content_id,
  p.reg_path_value,
  r.reg_last_updated_time
FROM   coct42_reg.reg_resource r
JOIN   coct42_reg.reg_path p
  ON   p.reg_path_id = r.reg_path_id
WHERE  p.reg_path_value LIKE
         '%5a1bffee-bafc-4f72-acec-d2275ecad872%'
ORDER BY p.reg_path_value, r.reg_name;
