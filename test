WITH txt AS (
  SELECT
    TO_CLOB(utl_raw.cast_to_varchar2(
      dbms_lob.substr(c.reg_content_data, 2000, 1)))    ||
    TO_CLOB(utl_raw.cast_to_varchar2(
      dbms_lob.substr(c.reg_content_data, 2000, 2001))) ||
    TO_CLOB(utl_raw.cast_to_varchar2(
      dbms_lob.substr(c.reg_content_data, 2000, 4001))) ||
    TO_CLOB(utl_raw.cast_to_varchar2(
      dbms_lob.substr(c.reg_content_data, 2000, 6001))) AS clob_txt
  FROM   coct42_reg.reg_content c
  WHERE  c.reg_content_id = 1781255
)
SELECT
  clob_txt                        AS full_text,
  -- any sequence references
  REGEXP_SUBSTR(clob_txt,
    'customsequences/[^"<>]+',
    1, 1, 'i')                   AS ref_1,
  REGEXP_SUBSTR(clob_txt,
    'customsequences/[^"<>]+',
    1, 2, 'i')                   AS ref_2,
  REGEXP_SUBSTR(clob_txt,
    'customsequences/[^"<>]+',
    1, 3, 'i')                   AS ref_3,
  -- suspend check
  CASE
    WHEN INSTR(UPPER(clob_txt), 'SUSPEND') > 0
      THEN 'Has suspend'
    ELSE 'No suspend'
  END                             AS suspend_check,
  -- 300 chars around suspend if found
  SUBSTR(clob_txt,
    GREATEST(INSTR(UPPER(clob_txt), 'SUSPEND') - 30, 1),
    300)                           AS suspend_context
FROM   txt;
