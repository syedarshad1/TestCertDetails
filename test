WITH api_blob AS (
  -- Extract inSequence and outSequence from API blob
  SELECT
    a.API_NAME,
    a.API_VERSION,
    REGEXP_SUBSTR(
      TO_CLOB(utl_raw.cast_to_varchar2(
        dbms_lob.substr(c.reg_content_data, 2000, 1)))  ||
      TO_CLOB(utl_raw.cast_to_varchar2(
        dbms_lob.substr(c.reg_content_data, 2000, 2001)))||
      TO_CLOB(utl_raw.cast_to_varchar2(
        dbms_lob.substr(c.reg_content_data, 2000, 4001))),
      '<inSequence>([^<]+)</inSequence>',
      1, 1, 'n', 1)               AS in_seq_from_blob,
    REGEXP_SUBSTR(
      TO_CLOB(utl_raw.cast_to_varchar2(
        dbms_lob.substr(c.reg_content_data, 2000, 1)))  ||
      TO_CLOB(utl_raw.cast_to_varchar2(
        dbms_lob.substr(c.reg_content_data, 2000, 2001)))||
      TO_CLOB(utl_raw.cast_to_varchar2(
        dbms_lob.substr(c.reg_content_data, 2000, 4001))),
      '<outSequence>([^<]+)</outSequence>',
      1, 1, 'n', 1)               AS out_seq_from_blob
  FROM   COCT42_AM.AM_API a
  JOIN   coct42_reg.reg_resource r
    ON   r.reg_name = 'api'
  JOIN   coct42_reg.reg_path p
    ON   p.reg_path_id = r.reg_path_id
    AND  p.reg_path_value LIKE
           '%' || a.API_UUID || '%'
  JOIN   coct42_reg.reg_content c
    ON   c.reg_content_id = r.reg_content_id
  WHERE  a.API_NAME    = 'PaymentOrderManagement'
    AND  a.API_VERSION IN ('5.1.4', '1.1')
),
provider_seq AS (
  -- Provider path in/out sequences for these two APIs
  SELECT
    REGEXP_SUBSTR(p.reg_path_value,
      '/provider/[^/]+/([^/]+)/[^/]+/(in|out)$',
      1, 1, 'i', 1)             AS api_name,
    REGEXP_SUBSTR(p.reg_path_value,
      '/provider/[^/]+/[^/]+/([^/]+)/(in|out)$',
      1, 1, 'i', 1)             AS api_version,
    REGEXP_SUBSTR(p.reg_path_value,
      '/(in|out)$',
      1, 1, 'i', 1)             AS seq_type,
    MAX(r.reg_name) KEEP
      (DENSE_RANK LAST ORDER BY r.reg_last_updated_time)
      AS seq_name
  FROM   coct42_reg.reg_resource r
  JOIN   coct42_reg.reg_path p
    ON   p.reg_path_id = r.reg_path_id
  WHERE  (
           p.reg_path_value LIKE
             '%/PaymentOrderManagement/5.1.4/in'
        OR p.reg_path_value LIKE
             '%/PaymentOrderManagement/5.1.4/out'
        OR p.reg_path_value LIKE
             '%/PaymentOrderManagement/1.1/in'
        OR p.reg_path_value LIKE
             '%/PaymentOrderManagement/1.1/out'
         )
    AND  r.reg_name       IS NOT NULL
    AND  r.reg_content_id IS NOT NULL
  GROUP BY
    REGEXP_SUBSTR(p.reg_path_value,
      '/provider/[^/]+/([^/]+)/[^/]+/(in|out)$',
      1, 1, 'i', 1),
    REGEXP_SUBSTR(p.reg_path_value,
      '/provider/[^/]+/[^/]+/([^/]+)/(in|out)$',
      1, 1, 'i', 1),
    REGEXP_SUBSTR(p.reg_path_value,
      '/(in|out)$',
      1, 1, 'i', 1)
)
SELECT
  ab.API_NAME,
  ab.API_VERSION,
  COALESCE(pin.seq_name,
           ab.in_seq_from_blob,
           'None')               AS in_sequence_name,
  CASE
    WHEN pin.seq_name        IS NOT NULL THEN 'Provider path'
    WHEN ab.in_seq_from_blob IS NOT NULL THEN 'Global (API blob tag)'
    ELSE 'None'
  END                             AS in_sequence_source,
  COALESCE(pout.seq_name,
           ab.out_seq_from_blob,
           'None')               AS out_sequence_name,
  CASE
    WHEN pout.seq_name        IS NOT NULL THEN 'Provider path'
    WHEN ab.out_seq_from_blob IS NOT NULL THEN 'Global (API blob tag)'
    ELSE 'None'
  END                             AS out_sequence_source
FROM   api_blob ab
LEFT JOIN provider_seq pin
  ON   pin.api_name    = ab.API_NAME
  AND  pin.api_version = ab.API_VERSION
  AND  pin.seq_type    = 'in'
LEFT JOIN provider_seq pout
  ON   pout.api_name    = ab.API_NAME
  AND  pout.api_version = ab.API_VERSION
  AND  pout.seq_type    = 'out'
ORDER BY ab.API_VERSION;
