SELECT
  a.API_NAME,
  a.API_VERSION,
  CASE
    WHEN DBMS_LOB.INSTR(UPPER(c.reg_content_data),'SUSPEND')>0
      THEN 'Has suspend'
    ELSE 'No suspend'
  END AS suspend_found,
  CASE
    WHEN DBMS_LOB.INSTR(c.reg_content_data,
           'suspendDuration'||CHR(34)||':'||CHR(34)||'0'||CHR(34))>0
      THEN 'suspendDuration=0 found'
    ELSE 'not found'
  END AS suspend_dur_check
FROM   COCT42_AM.AM_API a
JOIN   coct42_reg.reg_resource r
  ON   r.reg_name = 'api'
JOIN   coct42_reg.reg_path p
  ON   p.reg_path_id = r.reg_path_id
  AND  p.reg_path_value LIKE '%5a1bffee-bafc-4f72-acec-d2275ecad872%'
JOIN   coct42_reg.reg_content c
  ON   c.reg_content_id = r.reg_content_id
WHERE  a.API_UUID = '5a1bffee-bafc-4f72-acec-d2275ecad872';
