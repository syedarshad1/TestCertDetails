WITH reg_apis AS (
  SELECT
    REGEXP_SUBSTR(p.reg_path_value,
      '/apis/([0-9a-fA-F-]{36})/',
      1, 1, NULL, 1)             AS api_uuid,
    TO_NUMBER(REGEXP_SUBSTR(p.reg_path_value,
      '/apis/[0-9a-fA-F-]{36}/([0-9]+)',
      1, 1, NULL, 1))            AS rev,
    r.reg_content_id
  FROM   coct42_reg.reg_resource r
  JOIN   coct42_reg.reg_path p
    ON   p.reg_path_id = r.reg_path_id
  WHERE  r.reg_name = 'api'
    AND  p.reg_path_value LIKE
         '/_system/governance/apimgt/applicationdata/apis/%'
),
latest_rev AS (
  SELECT
    api_uuid,
    MAX(reg_content_id) KEEP
      (DENSE_RANK LAST ORDER BY rev) AS reg_content_id
  FROM   reg_apis
  WHERE  api_uuid IS NOT NULL
  GROUP BY api_uuid
),
raw_blob AS (
  SELECT
    lr.api_uuid,
    utl_raw.cast_to_varchar2(
      dbms_lob.substr(c.reg_content_data, 2000, 1))    ||
    utl_raw.cast_to_varchar2(
      dbms_lob.substr(c.reg_content_data, 2000, 2001)) ||
    utl_raw.cast_to_varchar2(
      dbms_lob.substr(c.reg_content_data, 2000, 4001)) AS blob_txt
  FROM   latest_rev lr
  LEFT JOIN coct42_reg.reg_content c
    ON   c.reg_content_id = lr.reg_content_id
),
ep_block AS (
  -- Extract just the production_endpoints block
  SELECT
    api_uuid,
    SUBSTR(blob_txt,
      INSTR(blob_txt, 'production_endpoints'),
      INSTR(blob_txt, '}}',
        INSTR(blob_txt, 'production_endpoints')) -
      INSTR(blob_txt, 'production_endpoints') + 2
    )                             AS prod_block
  FROM   raw_blob
  WHERE  INSTR(blob_txt, 'production_endpoints') > 0
),
ep_parsed AS (
  SELECT
    api_uuid,
    -- Production URL (clean \/ to /)
    REPLACE(
      SUBSTR(prod_block,
        INSTR(prod_block, 'url'':''') + 6,
        INSTR(prod_block, '''',
          INSTR(prod_block, 'url'':''') + 6) -
        INSTR(prod_block, 'url'':''') - 6),
    '\/', '/')                    AS production_url,
    -- Timeout ms
    CASE WHEN INSTR(prod_block, 'actionDuration') > 0
      THEN SUBSTR(prod_block,
             INSTR(prod_block, 'actionDuration'':''') + 16,
             INSTR(prod_block, '''',
               INSTR(prod_block, 'actionDuration'':''') + 16) -
             INSTR(prod_block, 'actionDuration'':''') - 16)
    END                           AS timeout_ms,
    -- suspendDuration
    CASE WHEN INSTR(prod_block, 'suspendDuration') > 0
      THEN SUBSTR(prod_block,
             INSTR(prod_block, 'suspendDuration'':''') + 17,
             INSTR(prod_block, '''',
               INSTR(prod_block, 'suspendDuration'':''') + 17) -
             INSTR(prod_block, 'suspendDuration'':''') - 17)
    END                           AS suspend_duration,
    -- suspendMaxDuration
    CASE WHEN INSTR(prod_block, 'suspendMaxDuration') > 0
      THEN SUBSTR(prod_block,
             INSTR(prod_block, 'suspendMaxDuration'':''') + 20,
             INSTR(prod_block, '''',
               INSTR(prod_block, 'suspendMaxDuration'':''') + 20) -
             INSTR(prod_block, 'suspendMaxDuration'':''') - 20)
    END                           AS suspend_max_duration,
    -- suspendErrorCode
    CASE WHEN INSTR(prod_block, 'suspendErrorCode') > 0
      THEN SUBSTR(prod_block,
             INSTR(prod_block, 'suspendErrorCode'':[') + 18,
             INSTR(prod_block, ']',
               INSTR(prod_block, 'suspendErrorCode'':[') + 18) -
             INSTR(prod_block, 'suspendErrorCode'':[') - 18)
    END                           AS suspend_error_code,
    -- actionSelect
    CASE WHEN INSTR(prod_block, 'actionSelect') > 0
      THEN SUBSTR(prod_block,
             INSTR(prod_block, 'actionSelect'':''') + 14,
             INSTR(prod_block, '''',
               INSTR(prod_block, 'actionSelect'':''') + 14) -
             INSTR(prod_block, 'actionSelect'':''') - 14)
    END                           AS action_select
  FROM   ep_block
)
SELECT
  a.API_NAME,
  a.API_VERSION,
  a.CONTEXT,
  a.STATUS,
  a.ORGANIZATION                  AS TENANT,
  a.UPDATED_TIME,
  COALESCE(ep.production_url,      'Not found') AS PRODUCTION_URL,
  COALESCE(ep.timeout_ms,          'Not set')   AS TIMEOUT_MS,
  COALESCE(ep.suspend_duration,    'Not set')   AS SUSPEND_DURATION,
  COALESCE(ep.suspend_max_duration,'Not set')   AS SUSPEND_MAX_DURATION,
  COALESCE(ep.suspend_error_code,  'Not set')   AS SUSPEND_ERROR_CODE,
  COALESCE(ep.action_select,       'Not set')   AS ACTION_SELECT
FROM   COCT42_AM.AM_API a
LEFT JOIN ep_parsed ep
  ON   ep.api_uuid = a.API_UUID
ORDER BY a.ORGANIZATION, a.API_NAME, a.API_VERSION;
