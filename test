WITH params AS (
  -- Change UUID here only
  SELECT '5c663424-e253-44cb-b13a-965e59b65bf1' AS api_uuid
  FROM   dual
),
base_path AS (
  -- Build the base path prefix for this UUID
  SELECT
    '/_system/governance/apimgt/applicationdata/apis/'
    || p.api_uuid                  AS base
  FROM   params p
),
latest_rev AS (
  -- Find highest revision number under this UUID
  SELECT
    MAX(TO_NUMBER(REGEXP_SUBSTR(
      rp.reg_path_value,
      '/([0-9]+)(/|$)',
      1, 1, NULL, 1)))          AS rev
  FROM   coct42_reg.reg_path rp
  CROSS JOIN base_path bp
  WHERE  rp.reg_path_value LIKE bp.base || '/%'
),
target_paths AS (
  -- Build exact paths for api, in, out, fault
  SELECT bp.base || '/' || lr.rev        AS target_path, 'api'   AS res_type FROM base_path bp CROSS JOIN latest_rev lr
  UNION ALL
  SELECT bp.base || '/' || lr.rev || '/in',    'in'    FROM base_path bp CROSS JOIN latest_rev lr
  UNION ALL
  SELECT bp.base || '/' || lr.rev || '/out',   'out'   FROM base_path bp CROSS JOIN latest_rev lr
  UNION ALL
  SELECT bp.base || '/' || lr.rev || '/fault', 'fault' FROM base_path bp CROSS JOIN latest_rev lr
),
decoded AS (
  -- Join to get content and decode chunks
  SELECT
    tp.res_type,
    r.reg_name,
    utl_raw.cast_to_varchar2(
      dbms_lob.substr(c.reg_content_data, 2000, 1))   AS chunk1,
    utl_raw.cast_to_varchar2(
      dbms_lob.substr(c.reg_content_data, 2000, 2001)) AS chunk2,
    utl_raw.cast_to_varchar2(
      dbms_lob.substr(c.reg_content_data, 2000, 4001)) AS chunk3
  FROM   target_paths tp
  JOIN   coct42_reg.reg_path rp
    ON   rp.reg_path_value = tp.target_path
  JOIN   coct42_reg.reg_resource r
    ON   r.reg_path_id     = rp.reg_path_id
    AND  r.reg_content_id  IS NOT NULL
  JOIN   coct42_reg.reg_content c
    ON   c.reg_content_id  = r.reg_content_id
)
SELECT
  res_type,
  reg_name,
  CASE
    WHEN INSTR(UPPER(chunk1),'SUSPEND')>0
      OR   INSTR(UPPER(chunk2),'SUSPEND')>0
      OR   INSTR(UPPER(chunk3),'SUSPEND')>0
      THEN 'Yes'
    ELSE 'No'
  END                             AS suspend_found,
  CASE
    WHEN INSTR(UPPER(chunk1),'SUSPEND')>0
      THEN SUBSTR(chunk1,
             GREATEST(INSTR(UPPER(chunk1),'SUSPEND')-20,1),300)
    WHEN INSTR(UPPER(chunk2),'SUSPEND')>0
      THEN SUBSTR(chunk2,
             GREATEST(INSTR(UPPER(chunk2),'SUSPEND')-20,1),300)
    WHEN INSTR(UPPER(chunk3),'SUSPEND')>0
      THEN SUBSTR(chunk3,
             GREATEST(INSTR(UPPER(chunk3),'SUSPEND')-20,1),300)
    ELSE 'No suspend found'
  END                             AS suspend_context,
  CASE
    WHEN INSTR(UPPER(chunk1),'CUSTOMSEQUENCES')>0
      THEN SUBSTR(chunk1,
             INSTR(UPPER(chunk1),'CUSTOMSEQUENCES'),200)
    WHEN INSTR(UPPER(chunk2),'CUSTOMSEQUENCES')>0
      THEN SUBSTR(chunk2,
             INSTR(UPPER(chunk2),'CUSTOMSEQUENCES'),200)
    WHEN INSTR(UPPER(chunk3),'CUSTOMSEQUENCES')>0
      THEN SUBSTR(chunk3,
             INSTR(UPPER(chunk3),'CUSTOMSEQUENCES'),200)
    ELSE 'No global seq reference'
  END                             AS global_seq_ref
FROM   decoded
ORDER BY
  CASE res_type
    WHEN 'api'   THEN 1
    WHEN 'in'    THEN 2
    WHEN 'out'   THEN 3
    WHEN 'fault' THEN 4
  END;
