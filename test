WITH latest_resources AS (
  -- Get latest revision number for this API UUID
  SELECT
    MAX(TO_NUMBER(REGEXP_SUBSTR(p.reg_path_value,
      '/apis/[0-9a-fA-F-]{36}/([0-9]+)',
      1, 1, NULL, 1)))          AS latest_rev
  FROM   coct42_reg.reg_path p
  WHERE  p.reg_path_value LIKE
           '/_system/governance/apimgt/applicationdata/apis/5c663424-e253-44cb-b13a-965e59b65bf1/%'
),
seq_content AS (
  -- Get content IDs for api, in, out, fault of latest revision
  SELECT
    r.reg_name,
    REGEXP_SUBSTR(p.reg_path_value,
      '/(api|in|out|fault)$',
      1, 1, 'i', 1)             AS resource_type,
    r.reg_content_id
  FROM   coct42_reg.reg_resource r
  JOIN   coct42_reg.reg_path p
    ON   p.reg_path_id = r.reg_path_id
  CROSS JOIN latest_resources lr
  WHERE  p.reg_path_value LIKE
           '/_system/governance/apimgt/applicationdata/apis/5c663424-e253-44cb-b13a-965e59b65bf1/'
           || lr.latest_rev || '/%'
    AND  REGEXP_LIKE(p.reg_path_value, '/(api|in|out|fault)$', 'i')
    AND  r.reg_content_id IS NOT NULL
),
decoded AS (
  -- Decode each resource blob into chunks
  SELECT
    s.reg_name,
    s.resource_type,
    utl_raw.cast_to_varchar2(
      dbms_lob.substr(c.reg_content_data, 2000, 1))    AS chunk1,
    utl_raw.cast_to_varchar2(
      dbms_lob.substr(c.reg_content_data, 2000, 2001))  AS chunk2,
    utl_raw.cast_to_varchar2(
      dbms_lob.substr(c.reg_content_data, 2000, 4001))  AS chunk3
  FROM   seq_content s
  JOIN   coct42_reg.reg_content c
    ON   c.reg_content_id = s.reg_content_id
)
SELECT
  resource_type,
  reg_name,
  -- Suspension check across all chunks
  CASE
    WHEN INSTR(UPPER(chunk1), 'SUSPEND') > 0
      THEN SUBSTR(chunk1,
             GREATEST(INSTR(UPPER(chunk1), 'SUSPEND') - 20, 1), 300)
    WHEN INSTR(UPPER(chunk2), 'SUSPEND') > 0
      THEN SUBSTR(chunk2,
             GREATEST(INSTR(UPPER(chunk2), 'SUSPEND') - 20, 1), 300)
    WHEN INSTR(UPPER(chunk3), 'SUSPEND') > 0
      THEN SUBSTR(chunk3,
             GREATEST(INSTR(UPPER(chunk3), 'SUSPEND') - 20, 1), 300)
    ELSE 'No suspend'
  END                             AS suspend_context,
  -- Global sequence references
  CASE
    WHEN INSTR(chunk1, 'customsequences') > 0
      THEN SUBSTR(chunk1,
             INSTR(chunk1, 'customsequences'),
             200)
    WHEN INSTR(chunk2, 'customsequences') > 0
      THEN SUBSTR(chunk2,
             INSTR(chunk2, 'customsequences'),
             200)
    WHEN INSTR(chunk3, 'customsequences') > 0
      THEN SUBSTR(chunk3,
             INSTR(chunk3, 'customsequences'),
             200)
    ELSE 'No global seq reference'
  END                             AS global_seq_ref,
  -- endpointConfig suspension (api blob only)
  CASE
    WHEN resource_type = 'api'
     AND INSTR(chunk1, 'suspendMaxDuration":"0"') > 0
      THEN 'Suspension disabled (endpointConfig)'
    WHEN resource_type = 'api'
     AND INSTR(chunk1, 'suspendErrorCode') > 0
      THEN 'Active suspension (endpointConfig)'
    WHEN resource_type = 'api'
      THEN 'No suspend in endpointConfig'
    ELSE '-'
  END                             AS endpoint_config_suspend
FROM   decoded
ORDER BY
  CASE resource_type
    WHEN 'api'   THEN 1
    WHEN 'in'    THEN 2
    WHEN 'out'   THEN 3
    WHEN 'fault' THEN 4
  END;
