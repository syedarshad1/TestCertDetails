WITH latest AS (
  SELECT
    MAX(r.reg_content_id) KEEP
      (DENSE_RANK LAST ORDER BY
        TO_NUMBER(REGEXP_SUBSTR(p.reg_path_value,
          '/apis/[0-9a-fA-F-]{36}/([0-9]+)',
          1, 1, NULL, 1))
      ) AS reg_content_id
  FROM   coct42_reg.reg_resource r
  JOIN   coct42_reg.reg_path p
    ON   p.reg_path_id = r.reg_path_id
  WHERE  r.reg_name = 'api'
    AND  p.reg_path_value LIKE
         '%5c663424-e253-44cb-b13a-965e59b65bf1%'
),
txt AS (
  SELECT
    TO_CLOB(utl_raw.cast_to_varchar2(
      dbms_lob.substr(c.reg_content_data, 2000, 1)))    ||
    TO_CLOB(utl_raw.cast_to_varchar2(
      dbms_lob.substr(c.reg_content_data, 2000, 2001))) ||
    TO_CLOB(utl_raw.cast_to_varchar2(
      dbms_lob.substr(c.reg_content_data, 2000, 4001))) ||
    TO_CLOB(utl_raw.cast_to_varchar2(
      dbms_lob.substr(c.reg_content_data, 2000, 6001))) AS clob_txt
  FROM   latest l
  JOIN   coct42_reg.reg_content c
    ON   c.reg_content_id = l.reg_content_id
)
SELECT
  -- inSequence tag
  REGEXP_SUBSTR(clob_txt,
    '<inSequence>.*?</inSequence>',
    1, 1, 'n')                   AS in_sequence_tag,
  -- outSequence tag
  REGEXP_SUBSTR(clob_txt,
    '<outSequence>.*?</outSequence>',
    1, 1, 'n')                   AS out_sequence_tag,
  -- any customsequences reference
  REGEXP_SUBSTR(clob_txt,
    'customsequences/[^<">]+',
    1, 1, 'i')                   AS custom_seq_ref
FROM   txt;
